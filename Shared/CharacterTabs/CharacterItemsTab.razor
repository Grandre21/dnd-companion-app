@using DndCompanion.Models
@inject SupabaseService SupabaseService
@inject ConfirmService Confirm

<div class="inventory-header">
    <p class="section-header" style="margin: 0;">INVENTARIO</p>
    <p class="inventory-summary">@Items.Count oggetti · Peso @FormatWeight(TotalInventoryWeight) kg</p>
</div>
<div class="inventory-section">

    @if (CanEditInventory)
    {
        @if (!isAddingItem)
        {
            <button type="button" class="inv-add-btn" @onclick="OpenAddItemForm">
                + Aggiungi oggetto
            </button>
        }
        else
        {
            <div class="inv-form">
                <div class="inv-form-grid">
                    <div class="field field-full">
                        <label>Nome</label>
                        <input type="text" class="input" maxlength="80"
                               placeholder="Nome dell'oggetto"
                               @bind="newItemDraft.Name" />
                    </div>

                    <div class="field">
                        <label>Quantità</label>
                        <input type="number" class="input" min="1" @bind="newItemDraft.Quantity" />
                    </div>

                    <div class="field">
                        <label>Peso</label>
                        <input type="number" class="input" step="0.1" min="0"
                               @bind="newItemDraft.Weight" />
                    </div>

                    <div class="field field-full">
                        <label>Tipo</label>
                        <select class="input" @bind="newItemDraft.ItemType">
                            @foreach (var o in ItemTypeOptions)
                            {
                                <option value="@o.Value">@o.Label</option>
                            }
                        </select>
                    </div>

                    <div class="field field-full">
                        <label>Descrizione (opzionale)</label>
                        <textarea class="input" rows="3"
                                  @bind="newItemDraft.Description"></textarea>
                    </div>
                </div>

                <div class="inv-form-actions">
                    <button type="button" class="primary-btn"
                            @onclick="SaveNewItemAsync"
                            disabled="@isSavingInventory">
                        @(isSavingInventory ? "Salvataggio..." : "Salva")
                    </button>
                    <button type="button" class="secondary-btn"
                            @onclick="CancelAddItem"
                            disabled="@isSavingInventory">
                        Annulla
                    </button>
                </div>
            </div>
        }
    }

    @if (IsLoading)
    {
        <LoadingSpinner Text="Caricamento inventario..." />
    }
    else if (Items.Count == 0)
    {
        <div class="inv-empty">Nessun oggetto nell'inventario.</div>
    }
    else
    {
        <div class="inv-list">
            @foreach (var item in Items)
            {
                var isItemExpanded = expandedItemId == item.Id;
                var isWeapon = string.Equals(item.ItemType, "weapon", StringComparison.OrdinalIgnoreCase);
                var hasWeaponStats = isWeapon &&
                    (!string.IsNullOrWhiteSpace(item.AttackBonus) ||
                     !string.IsNullOrWhiteSpace(item.Damage) ||
                     !string.IsNullOrWhiteSpace(item.DamageType));
                <div class="inv-item @(item.IsEquipped ? "equipped" : "")">
                    <div class="inv-row">
                        <button type="button" class="inv-name-btn"
                                @onclick="() => ToggleItemExpand(item.Id)">
                            @if (isWeapon)
                            {
                                <span class="weapon-badge" title="Arma">⚔</span>
                            }
                            else if (item.IsEquipped)
                            {
                                <span class="eq-icon" title="Equipaggiato">⚔️</span>
                            }
                            <span class="inv-name-text">@item.Name</span>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <span class="inv-exp-icon">@(isItemExpanded ? "▾" : "▸")</span>
                            }
                        </button>

                        @if (CanEditInventory)
                        {
                            <div class="qty-controls">
                                <button type="button" class="qty-btn qty-minus"
                                        @onclick="() => AdjustQuantityAsync(item, -1)"
                                        disabled="@isSavingInventory">
                                    −
                                </button>
                                <span class="qty-value">@item.Quantity</span>
                                <button type="button" class="qty-btn qty-plus"
                                        @onclick="() => AdjustQuantityAsync(item, 1)"
                                        disabled="@isSavingInventory">
                                    +
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="qty-readonly">×@item.Quantity</div>
                        }
                    </div>

                    @if (hasWeaponStats)
                    {
                        <p class="inv-weapon-stats">
                            @if (!string.IsNullOrWhiteSpace(item.AttackBonus)) { <span>@item.AttackBonus</span> }
                            @if (!string.IsNullOrWhiteSpace(item.Damage)) { <span>· @item.Damage @item.DamageType?.ToLower()</span> }
                        </p>
                    }

                    <div class="inv-meta">
                        @if (!string.IsNullOrWhiteSpace(item.ItemType))
                        {
                            <span class="inv-type-badge">@(isWeapon ? "Arma" : item.ItemType)</span>
                        }
                        @if (item.Weight.HasValue)
                        {
                            <span class="inv-weight">@FormatWeight(item.Weight.Value * item.Quantity)</span>
                        }

                        @if (CanEditInventory)
                        {
                            <label class="inv-eq-toggle">
                                <input type="checkbox" checked="@item.IsEquipped"
                                       @onchange="@(e => ToggleEquippedAsync(item, (bool)(e.Value ?? false)))"
                                       disabled="@isSavingInventory" />
                                <span>Equipaggiato</span>
                            </label>

                            <button type="button" class="inv-delete-btn"
                                    title="Elimina oggetto"
                                    @onclick="() => DeleteItemAsync(item)"
                                    disabled="@isSavingInventory">
                                🗑️
                            </button>
                        }
                    </div>

                    @if (isItemExpanded && !string.IsNullOrWhiteSpace(item.Description))
                    {
                        <div class="inv-description">@item.Description</div>
                    }
                </div>
            }
        </div>
    }
</div>

<p class="section-header">DENARO</p>
@if (isEditingMoney)
{
    <div class="money-editor">
        <div class="money-field">
            <label>MP</label>
            <input type="number" min="0" @bind="Character.PlatinumPieces" />
        </div>
        <div class="money-field">
            <label>MO</label>
            <input type="number" min="0" @bind="Character.GoldPieces" />
        </div>
        <div class="money-field">
            <label>ME</label>
            <input type="number" min="0" @bind="Character.ElectrumPieces" />
        </div>
        <div class="money-field">
            <label>MA</label>
            <input type="number" min="0" @bind="Character.SilverPieces" />
        </div>
        <div class="money-field">
            <label>MR</label>
            <input type="number" min="0" @bind="Character.CopperPieces" />
        </div>
        <div class="money-editor-actions">
            <button class="money-save-btn" @onclick="SaveMoney">Salva</button>
        </div>
    </div>
}
else
{
    <div class="money-compact @(CanEdit ? "editable" : "")" @onclick="@(() => { if (CanEdit) isEditingMoney = true; })">
        <span class="money-icon">🪙</span>
        <span class="money-summary">@FormatMoney()</span>
        @if (CanEdit)
        {
            <span class="money-edit-hint">✎</span>
        }
    </div>
}

<p class="section-header">SINTONIE OGGETTI MAGICI</p>
<div class="attunements-compact">
    @for (int slot = 1; slot <= 3; slot++)
    {
        var n = slot;
        var current = AttunementValue(n);
        <div class="attunement-row">
            <span class="attunement-icon">✦</span>
            @if (CanEdit)
            {
                <input type="text" class="attunement-input" maxlength="80"
                       placeholder="(slot libero)"
                       value="@current"
                       @onchange="@(e => SetAttunementAsync(n, e.Value?.ToString()))" />
            }
            else
            {
                <span class="attunement-text @(string.IsNullOrWhiteSpace(current) ? "empty" : "")">
                    @(string.IsNullOrWhiteSpace(current) ? "(slot libero)" : current)
                </span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public Character Character { get; set; } = default!;
    [Parameter] public bool CanEdit { get; set; }
    [Parameter] public IReadOnlyList<InventoryItem> Items { get; set; } = Array.Empty<InventoryItem>();
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>Persistenza di campi Character (denaro/sintonie): il genitore fa SaveCharacterAsync.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }
    /// <summary>Modifica strutturale dell'inventario (add/delete): il genitore ricarica la lista.</summary>
    [Parameter] public EventCallback OnInventoryChanged { get; set; }
    /// <summary>Messaggio d'errore da mostrare nel banner del genitore (null = pulisci).</summary>
    [Parameter] public EventCallback<string?> OnError { get; set; }

    private bool isAddingItem;
    private InventoryItem newItemDraft = new();
    private bool isSavingInventory;
    private string? expandedItemId;
    private bool isEditingMoney;
    private string? _lastId;

    // Le armi (Value "weapon") vengono mostrate nella sezione Combattimento. Le altre voci usano Value == Label.
    private static readonly (string Value, string Label)[] ItemTypeOptions =
    {
        ("Altro", "Altro"),
        ("weapon", "Arma"),
        ("Armatura", "Armatura"),
        ("Pozione", "Pozione"),
        ("Pergamena", "Pergamena"),
        ("Strumento", "Strumento"),
        ("Tesoro", "Tesoro")
    };

    private bool CanEditInventory => CanEdit;

    private double TotalInventoryWeight => Items.Sum(i => (i.Weight ?? 0) * i.Quantity);

    // Reset dello stato UI locale al cambio di PG (prima lo faceva il genitore alla selezione).
    protected override void OnParametersSet()
    {
        if (Character.Id != _lastId)
        {
            _lastId = Character.Id;
            expandedItemId = null;
            isAddingItem = false;
            isEditingMoney = false;
            newItemDraft = new InventoryItem();
        }
    }

    private void ToggleItemExpand(string id) => expandedItemId = expandedItemId == id ? null : id;

    private async Task OpenAddItemForm()
    {
        if (!CanEditInventory) return;
        newItemDraft = new InventoryItem
        {
            CharacterId = Character.Id,
            Quantity = 1,
            ItemType = ItemTypeOptions[0].Value
        };
        isAddingItem = true;
        await OnError.InvokeAsync(null);
    }

    private void CancelAddItem()
    {
        isAddingItem = false;
        newItemDraft = new InventoryItem();
    }

    private async Task SaveNewItemAsync()
    {
        if (!CanEditInventory) return;

        if (string.IsNullOrWhiteSpace(newItemDraft.Name))
        {
            await OnError.InvokeAsync("Il nome dell'oggetto è obbligatorio");
            return;
        }
        if (newItemDraft.Quantity < 1) newItemDraft.Quantity = 1;

        isSavingInventory = true;
        await OnError.InvokeAsync(null);
        try
        {
            newItemDraft.CharacterId = Character.Id;
            var saved = await SupabaseService.CreateInventoryItemAsync(newItemDraft);
            if (saved is null)
            {
                await OnError.InvokeAsync("Il server non ha restituito l'oggetto salvato.");
                return;
            }
            isAddingItem = false;
            newItemDraft = new InventoryItem();
            await OnInventoryChanged.InvokeAsync(); // il genitore ricarica (lista ordinata + Combat aggiornato)
        }
        catch (Exception ex)
        {
            await OnError.InvokeAsync($"Errore creazione oggetto: {ex.Message}");
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task AdjustQuantityAsync(InventoryItem item, int delta)
    {
        if (!CanEditInventory) return;

        var newQty = item.Quantity + delta;

        if (newQty <= 0)
        {
            var confirmed = await Confirm.ShowAsync(
                $"Eliminare \"{item.Name}\" dall'inventario?");
            if (!confirmed) return;
            await DeleteItemInternalAsync(item);
            return;
        }

        var previous = item.Quantity;
        item.Quantity = newQty;
        isSavingInventory = true;
        await OnError.InvokeAsync(null);
        try
        {
            var saved = await SupabaseService.UpdateInventoryItemAsync(item);
            if (saved is not null)
            {
                item.Quantity = saved.Quantity;
            }
        }
        catch (Exception ex)
        {
            item.Quantity = previous;
            await OnError.InvokeAsync($"Errore salvataggio quantità: {ex.Message}");
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task ToggleEquippedAsync(InventoryItem item, bool newValue)
    {
        if (!CanEditInventory) return;
        if (item.IsEquipped == newValue) return;

        var previous = item.IsEquipped;
        item.IsEquipped = newValue;
        isSavingInventory = true;
        await OnError.InvokeAsync(null);
        try
        {
            var saved = await SupabaseService.UpdateInventoryItemAsync(item);
            if (saved is not null)
            {
                item.IsEquipped = saved.IsEquipped;
            }
        }
        catch (Exception ex)
        {
            item.IsEquipped = previous;
            await OnError.InvokeAsync($"Errore salvataggio equipaggiamento: {ex.Message}");
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task DeleteItemAsync(InventoryItem item)
    {
        if (!CanEditInventory) return;

        var confirmed = await Confirm.ShowAsync(
            $"Eliminare \"{item.Name}\" dall'inventario?");
        if (!confirmed) return;

        await DeleteItemInternalAsync(item);
    }

    private async Task DeleteItemInternalAsync(InventoryItem item)
    {
        isSavingInventory = true;
        await OnError.InvokeAsync(null);
        try
        {
            await SupabaseService.DeleteInventoryItemAsync(item.Id);
            if (expandedItemId == item.Id) expandedItemId = null;
            await OnInventoryChanged.InvokeAsync(); // il genitore ricarica (rimuove l'item + Combat aggiornato)
        }
        catch (Exception ex)
        {
            await OnError.InvokeAsync($"Errore eliminazione oggetto: {ex.Message}");
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private static string FormatWeight(double weight)
    {
        if (weight <= 0) return "0";
        return weight.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    // Stringa compatta delle sole valute > 0, in ordine di valore decrescente (MP>MO>ME>MA>MR).
    private string FormatMoney()
    {
        var parts = new List<string>();
        if (Character.PlatinumPieces > 0) parts.Add($"{Character.PlatinumPieces} MP");
        if (Character.GoldPieces > 0) parts.Add($"{Character.GoldPieces} MO");
        if (Character.ElectrumPieces > 0) parts.Add($"{Character.ElectrumPieces} ME");
        if (Character.SilverPieces > 0) parts.Add($"{Character.SilverPieces} MA");
        if (Character.CopperPieces > 0) parts.Add($"{Character.CopperPieces} MR");
        return parts.Count > 0 ? string.Join(" · ", parts) : "Nessuna moneta";
    }

    private async Task SaveMoney()
    {
        if (!CanEdit) return;
        Character.PlatinumPieces = Math.Max(0, Character.PlatinumPieces);
        Character.GoldPieces = Math.Max(0, Character.GoldPieces);
        Character.ElectrumPieces = Math.Max(0, Character.ElectrumPieces);
        Character.SilverPieces = Math.Max(0, Character.SilverPieces);
        Character.CopperPieces = Math.Max(0, Character.CopperPieces);
        await OnChanged.InvokeAsync();
        isEditingMoney = false;
    }

    private string? AttunementValue(int slot) => slot switch
    {
        1 => Character.AttunedItem1,
        2 => Character.AttunedItem2,
        3 => Character.AttunedItem3,
        _ => null
    };

    private async Task SetAttunementAsync(int slot, string? raw)
    {
        if (!CanEdit) return;
        var val = string.IsNullOrWhiteSpace(raw) ? null : raw.Trim();
        switch (slot)
        {
            case 1: Character.AttunedItem1 = val; break;
            case 2: Character.AttunedItem2 = val; break;
            case 3: Character.AttunedItem3 = val; break;
            default: return;
        }
        await OnChanged.InvokeAsync();
    }
}
