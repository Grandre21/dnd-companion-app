@using DndCompanion.Models

<div class="form-view">
    <div class="sheet-top">
        <button type="button" class="back-link" @onclick="@(() => OnCancel.InvokeAsync())">← Annulla</button>
    </div>

    <h2 class="form-title">
        @(string.IsNullOrEmpty(Draft.Id) ? "Nuovo Personaggio" : "Modifica Personaggio")
    </h2>

    <div class="form-accordion">

        @* ===================== 1. IDENTITÀ ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("identity")'>
                <span class="form-section-chevron">@(formSections["identity"] ? "▾" : "▸")</span>
                <span class="form-section-title">1. Identità</span>
            </button>
            @if (formSections["identity"])
            {
                <div class="form-section-body">
                    <div class="field">
                        <label>Nome</label>
                        <input type="text" class="input" maxlength="64" @bind="Draft.Name" />
                    </div>

                    <div class="field">
                        <label>Classe</label>
                        <select class="input" value="@CurrentClassSelection" @onchange="OnClassSelectionChanged">
                            <option value="">-- Seleziona --</option>
                            @foreach (var c in Classes.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                            <option value="@CustomOptionValue">Altro (testo libero)</option>
                        </select>
                        @if (isClassCustom)
                        {
                            <input type="text" class="input custom-input" maxlength="40"
                                   placeholder="Scrivi la classe"
                                   @bind="Draft.Class" @bind:event="oninput" />
                        }
                        @if (SelectedClassInfo is not null)
                        {
                            <div class="info-summary">
                                <strong>Dado vita:</strong> @(string.IsNullOrEmpty(SelectedClassInfo.HitDie) ? "—" : SelectedClassInfo.HitDie)
                                @if (!string.IsNullOrWhiteSpace(SelectedClassInfo.PrimaryAbility))
                                {
                                    <span> · <strong>Abilità primaria:</strong> @SelectedClassInfo.PrimaryAbility</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="field">
                        <label>Sottoclasse</label>
                        <input type="text" class="input" maxlength="60"
                               placeholder="es. Berserker, Campione, Evocatore..."
                               @bind="Draft.Subclass" />
                    </div>

                    <div class="field">
                        <label>Razza</label>
                        <select class="input" value="@CurrentRaceSelection" @onchange="OnRaceSelectionChanged">
                            <option value="">-- Seleziona --</option>
                            @foreach (var r in Races.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@r.Name">@r.Name</option>
                            }
                            <option value="@CustomOptionValue">Altro (testo libero)</option>
                        </select>
                        @if (isRaceCustom)
                        {
                            <input type="text" class="input custom-input" maxlength="40"
                                   placeholder="Scrivi la razza"
                                   @bind="Draft.Race" @bind:event="oninput" />
                        }
                        @if (SelectedRaceInfo is not null)
                        {
                            <div class="info-summary">
                                <strong>Bonus razziali:</strong> @FormatRaceBonuses(SelectedRaceInfo)
                                · <strong>Velocità:</strong> @SelectedRaceInfo.Speed
                            </div>
                        }
                    </div>

                    <div class="field">
                        <label>Livello</label>
                        <input type="number" class="input" min="1" max="20" @bind="Draft.Level" />
                    </div>

                    <div class="field">
                        <label>Background</label>
                        <input type="text" class="input" maxlength="60"
                               placeholder="es. Soldato, Criminale, Eremita..."
                               @bind="Draft.Background" />
                    </div>

                    <div class="field">
                        <label>Allineamento</label>
                        <select class="input" @bind="Draft.Alignment">
                            <option value="">-- Nessuno --</option>
                            <option value="Legale Buono">Legale Buono</option>
                            <option value="Neutrale Buono">Neutrale Buono</option>
                            <option value="Caotico Buono">Caotico Buono</option>
                            <option value="Legale Neutrale">Legale Neutrale</option>
                            <option value="Neutrale Puro">Neutrale Puro</option>
                            <option value="Caotico Neutrale">Caotico Neutrale</option>
                            <option value="Legale Malvagio">Legale Malvagio</option>
                            <option value="Neutrale Malvagio">Neutrale Malvagio</option>
                            <option value="Caotico Malvagio">Caotico Malvagio</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Punti Esperienza</label>
                        <input type="number" class="input" min="0" @bind="Draft.ExperiencePoints" />
                    </div>
                </div>
            }
        </div>

        @* ===================== 2. COMBATTIMENTO ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("combat")'>
                <span class="form-section-chevron">@(formSections["combat"] ? "▾" : "▸")</span>
                <span class="form-section-title">2. Combattimento</span>
            </button>
            @if (formSections["combat"])
            {
                <div class="form-section-body">
                    <div class="field">
                        <label>Classe Armatura</label>
                        <input type="number" class="input" min="0" max="40" @bind="Draft.ArmorClass" />
                    </div>

                    <div class="dual-field">
                        <div class="field">
                            <label>PF Correnti</label>
                            <input type="number" class="input" min="0" @bind="Draft.HitPoints" />
                        </div>
                        <div class="field">
                            <label>PF Massimi</label>
                            <input type="number" class="input" min="1" @bind="Draft.MaxHitPoints" />
                        </div>
                    </div>

                    <div class="field">
                        <label>PF Temporanei</label>
                        <input type="number" class="input" min="0" @bind="Draft.TempHitPoints" />
                    </div>

                    <div class="field">
                        <label>Velocità (m)</label>
                        <input type="number" class="input" min="0" @bind="Draft.Speed" />
                        <span class="field-hint">9m = 30 piedi (umano standard)</span>
                    </div>

                    <div class="field">
                        <label>Taglia</label>
                        <select class="input" @bind="Draft.Size">
                            <option value="Minuscola">Minuscola</option>
                            <option value="Piccola">Piccola</option>
                            <option value="Media">Media</option>
                            <option value="Grande">Grande</option>
                            <option value="Enorme">Enorme</option>
                            <option value="Mastodontica">Mastodontica</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Dadi Vita</label>
                        <input type="text" class="input" maxlength="40"
                               placeholder="es. 3d12 (barbaro) o 3d12+2d8 (multiclasse)"
                               @bind="Draft.HitDiceMax" />
                        <span class="field-hint">Numero e tipo dado per livello</span>
                    </div>

                    <div class="field">
                        <label>Dadi Vita spesi</label>
                        <input type="number" class="input" min="0" @bind="Draft.HitDiceSpent" />
                    </div>

                    <div class="derived-info">
                        Iniziativa: <strong>@FormatBonus(CharacterCalculations.GetInitiative(Draft))</strong>
                        · Bonus competenza: <strong>@FormatBonus(CharacterCalculations.GetProficiencyBonus(Draft.Level))</strong>
                        · Percezione passiva: <strong>@CharacterCalculations.GetPassivePerception(Draft)</strong>
                    </div>
                </div>
            }
        </div>

        @* ===================== 3. CARATTERISTICHE E COMPETENZE ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("stats")'>
                <span class="form-section-chevron">@(formSections["stats"] ? "▾" : "▸")</span>
                <span class="form-section-title">3. Caratteristiche e competenze</span>
            </button>
            @if (formSections["stats"])
            {
                <div class="form-section-body">
                    <div class="derived-info">
                        Competenza: <strong>@FormatBonus(CharacterCalculations.GetProficiencyBonus(Draft.Level))</strong>
                        · FOR <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Strength))</strong>
                        · DES <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Dexterity))</strong>
                        · COS <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Constitution))</strong>
                        · INT <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Intelligence))</strong>
                        · SAG <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Wisdom))</strong>
                        · CAR <strong>@FormatBonus(CharacterCalculations.GetModifier(Draft.Charisma))</strong>
                    </div>
                    <div class="score-grid">
                        <div class="field stat-field">
                            <label title="Forza">FOR</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Strength" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Strength))</span>
                        </div>
                        <div class="field stat-field">
                            <label title="Destrezza">DES</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Dexterity" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Dexterity))</span>
                        </div>
                        <div class="field stat-field">
                            <label title="Costituzione">COS</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Constitution" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Constitution))</span>
                        </div>
                        <div class="field stat-field">
                            <label title="Intelligenza">INT</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Intelligence" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Intelligence))</span>
                        </div>
                        <div class="field stat-field">
                            <label title="Saggezza">SAG</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Wisdom" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Wisdom))</span>
                        </div>
                        <div class="field stat-field">
                            <label title="Carisma">CAR</label>
                            <input type="number" class="input" min="1" max="30" @bind="Draft.Charisma" />
                            <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(Draft.Charisma))</span>
                        </div>
                    </div>

                    <div class="sub-block">
                        <p class="sub-block-title">TIRI SALVEZZA COMPETENTI</p>
                        <div class="checkbox-col">
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveStrength" /> <span>Forza</span></label>
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveDexterity" /> <span>Destrezza</span></label>
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveConstitution" /> <span>Costituzione</span></label>
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveIntelligence" /> <span>Intelligenza</span></label>
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveWisdom" /> <span>Saggezza</span></label>
                            <label class="checkbox-row"><input type="checkbox" @bind="Draft.ProfSaveCharisma" /> <span>Carisma</span></label>
                        </div>
                    </div>

                    <div class="sub-block">
                        <p class="sub-block-title">ABILITÀ COMPETENTI</p>
                        <div class="skill-head">
                            <span>Skill</span><span>Comp</span><span>Exp</span>
                        </div>

                        <p class="skill-group">FORZA</p>
                        <div class="skill-row">
                            <span class="skill-name">Atletica</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfAthletics" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpAthletics" />
                        </div>

                        <p class="skill-group">DESTREZZA</p>
                        <div class="skill-row">
                            <span class="skill-name">Acrobazia</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfAcrobatics" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpAcrobatics" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Rapidità di mano</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfSleightOfHand" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpSleightOfHand" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Furtività</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfStealth" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpStealth" />
                        </div>

                        <p class="skill-group">INTELLIGENZA</p>
                        <div class="skill-row">
                            <span class="skill-name">Arcano</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfArcana" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpArcana" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Storia</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfHistory" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpHistory" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Indagare</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfInvestigation" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpInvestigation" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Natura</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfNature" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpNature" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Religione</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfReligion" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpReligion" />
                        </div>

                        <p class="skill-group">SAGGEZZA</p>
                        <div class="skill-row">
                            <span class="skill-name">Addestrare animali</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfAnimalHandling" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpAnimalHandling" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Intuizione</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfInsight" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpInsight" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Medicina</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfMedicine" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpMedicine" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Percezione</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfPerception" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpPerception" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Sopravvivenza</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfSurvival" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpSurvival" />
                        </div>

                        <p class="skill-group">CARISMA</p>
                        <div class="skill-row">
                            <span class="skill-name">Inganno</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfDeception" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpDeception" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Intimidire</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfIntimidation" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpIntimidation" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Intrattenere</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfPerformance" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpPerformance" />
                        </div>
                        <div class="skill-row">
                            <span class="skill-name">Persuasione</span>
                            <input type="checkbox" class="skill-check" @bind="Draft.ProfPersuasion" />
                            <input type="checkbox" class="skill-check" @bind="Draft.ExpPersuasion" />
                        </div>
                        <p class="field-hint">L'Expertise senza Competenza non ha effetto: i calcoli lo ignorano.</p>
                    </div>
                </div>
            }
        </div>

        @* ===================== 4. DIFESE ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("defenses")'>
                <span class="form-section-chevron">@(formSections["defenses"] ? "▾" : "▸")</span>
                <span class="form-section-title">4. Difese</span>
            </button>
            @if (formSections["defenses"])
            {
                <div class="form-section-body">
                    <div class="field">
                        <label>Resistenze ai danni</label>
                        <textarea class="input" rows="2" placeholder="Contundente, Perforante, Tagliente"
                                  @bind="Draft.DamageResistances"></textarea>
                    </div>
                    <div class="field">
                        <label>Immunità ai danni</label>
                        <textarea class="input" rows="2" placeholder="Veleno, Necrotico"
                                  @bind="Draft.DamageImmunities"></textarea>
                    </div>
                    <div class="field">
                        <label>Vulnerabilità ai danni</label>
                        <textarea class="input" rows="2" placeholder="Fuoco, Radiante"
                                  @bind="Draft.DamageVulnerabilities"></textarea>
                    </div>
                    <div class="field">
                        <label>Immunità a condizioni</label>
                        <textarea class="input" rows="2" placeholder="Avvelenato, Spaventato, Charmato"
                                  @bind="Draft.ConditionImmunities"></textarea>
                    </div>
                    <p class="field-hint">Separa più voci con virgola.</p>
                </div>
            }
        </div>

        @* ===================== 5. ASPETTO E STORIA ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("lore")'>
                <span class="form-section-chevron">@(formSections["lore"] ? "▾" : "▸")</span>
                <span class="form-section-title">5. Aspetto e storia</span>
            </button>
            @if (formSections["lore"])
            {
                <div class="form-section-body">
                    <div class="field">
                        <label>Aspetto</label>
                        <textarea class="input" rows="3" placeholder="Altezza, capelli, occhi, segni distintivi..."
                                  @bind="Draft.Appearance"></textarea>
                    </div>
                    <div class="field">
                        <label>Storia / Backstory</label>
                        <textarea class="input" rows="6" placeholder="Origini, famiglia, eventi salienti..."
                                  @bind="Draft.Backstory"></textarea>
                    </div>
                    <div class="field">
                        <label>Lingue</label>
                        <input type="text" class="input" maxlength="200"
                               placeholder="Comune, Orchesco, Nanico..."
                               @bind="Draft.Languages" />
                    </div>
                    <div class="field">
                        <label>Tratti della specie</label>
                        <textarea class="input" rows="4" placeholder="Scurovisione, Resistenza Implacabile, Furia primordiale..."
                                  @bind="Draft.SpeciesTraits"></textarea>
                    </div>
                    <div class="field">
                        <label>Privilegi di classe</label>
                        <textarea class="input" rows="6" placeholder="Ira, Difesa senza armatura, Padronanza d'armi..."
                                  @bind="Draft.ClassFeatures"></textarea>
                    </div>
                    <div class="field">
                        <label>Talenti</label>
                        <textarea class="input" rows="4" placeholder="Occhio di Gargauth, Combattente difensivo..."
                                  @bind="Draft.Feats"></textarea>
                    </div>
                    <div class="field">
                        <label>Note libere</label>
                        <textarea class="input" rows="4" @bind="Draft.Notes"></textarea>
                    </div>
                </div>
            }
        </div>

        @* ===================== 6. RISORSE ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("resources")'>
                <span class="form-section-chevron">@(formSections["resources"] ? "▾" : "▸")</span>
                <span class="form-section-title">6. Risorse</span>
            </button>
            @if (formSections["resources"])
            {
                <div class="form-section-body">
                    <p class="sub-block-title">DENARI</p>
                    <div class="coins-input-row">
                        <div class="field coin-field">
                            <label title="Monete di Rame">MR</label>
                            <input type="number" class="input" min="0" @bind="Draft.CopperPieces" />
                        </div>
                        <div class="field coin-field">
                            <label title="Monete di Argento">MA</label>
                            <input type="number" class="input" min="0" @bind="Draft.SilverPieces" />
                        </div>
                        <div class="field coin-field">
                            <label title="Monete di Elettro">ME</label>
                            <input type="number" class="input" min="0" @bind="Draft.ElectrumPieces" />
                        </div>
                        <div class="field coin-field">
                            <label title="Monete di Oro">MO</label>
                            <input type="number" class="input" min="0" @bind="Draft.GoldPieces" />
                        </div>
                        <div class="field coin-field">
                            <label title="Monete di Platino">MP</label>
                            <input type="number" class="input" min="0" @bind="Draft.PlatinumPieces" />
                        </div>
                    </div>

                    <p class="sub-block-title">SINTONIE OGGETTI MAGICI</p>
                    <div class="field">
                        <label>Slot 1</label>
                        <input type="text" class="input" maxlength="80"
                               placeholder="Es. Spada vorpalina, Anello di protezione..."
                               @bind="Draft.AttunedItem1" />
                    </div>
                    <div class="field">
                        <label>Slot 2</label>
                        <input type="text" class="input" maxlength="80"
                               placeholder="Es. Spada vorpalina, Anello di protezione..."
                               @bind="Draft.AttunedItem2" />
                    </div>
                    <div class="field">
                        <label>Slot 3</label>
                        <input type="text" class="input" maxlength="80"
                               placeholder="Es. Spada vorpalina, Anello di protezione..."
                               @bind="Draft.AttunedItem3" />
                    </div>
                    <p class="field-hint">Massimo 3 oggetti magici sintonizzati attivamente.</p>
                </div>
            }
        </div>

        @* ===================== 7. INCANTESIMI ===================== *@
        <div class="form-section">
            <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("spellcasting")'>
                <span class="form-section-chevron">@(formSections["spellcasting"] ? "▾" : "▸")</span>
                <span class="form-section-title">7. Incantesimi</span>
            </button>
            @if (formSections["spellcasting"])
            {
                <div class="form-section-body">
                    <div class="field">
                        <label>Caratteristica da incantatore</label>
                        <select class="input" @bind="Draft.SpellcastingAbility">
                            <option value="">-- Nessuna (non incantatore) --</option>
                            <option value="intelligence">Intelligenza</option>
                            <option value="wisdom">Saggezza</option>
                            <option value="charisma">Carisma</option>
                        </select>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Draft.SpellcastingAbility))
                    {
                        <div class="derived-info">
                            CD Incantesimo: <strong>@(CharacterCalculations.GetSpellSaveDc(Draft) ?? 0)</strong>
                            · Bonus Attacco: <strong>@FormatBonus(CharacterCalculations.GetSpellAttackBonus(Draft) ?? 0)</strong>
                        </div>

                        <p class="sub-block-title">SLOT INCANTESIMO</p>
                        <div class="spell-slots-head">
                            <span>Livello</span><span>Massimi</span><span>Usati</span>
                        </div>
                        @for (int level = 1; level <= 9; level++)
                        {
                            var lvl = level;
                            <div class="spell-slot-input-row">
                                <span class="spell-slot-input-label">Liv @lvl</span>
                                <input type="number" class="input" min="0" max="9"
                                       value="@GetSpellSlotMax(Draft, lvl)"
                                       @onchange="e => OnSpellSlotMaxChanged(lvl, e)" />
                                <input type="number" class="input" min="0" max="9"
                                       value="@GetSpellSlotUsed(Draft, lvl)"
                                       @onchange="e => OnSpellSlotUsedChanged(lvl, e)" />
                            </div>
                        }
                        <p class="field-hint">Imposta gli slot massimi secondo la tabella della tua classe. Gli slot usati si gestiscono durante la sessione dal tab Magic della scheda.</p>
                    }
                </div>
            }
        </div>

    </div>

    <div class="form-actions">
        <button type="button" class="primary-btn" @onclick="@(() => OnSave.InvokeAsync())" disabled="@IsBusy">
            @(IsBusy ? "Salvataggio..." : "Salva")
        </button>
        <button type="button" class="secondary-btn" @onclick="@(() => OnCancel.InvokeAsync())" disabled="@IsBusy">
            Annulla
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Character Draft { get; set; } = default!;
    [Parameter] public List<CharacterClass> Classes { get; set; } = new();
    [Parameter] public List<Race> Races { get; set; } = new();
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private const string CustomOptionValue = "__custom__";
    private bool isClassCustom;
    private bool isRaceCustom;
    private Character? _lastDraft;

    // ===== Sezioni a fisarmonica del form (apertura/chiusura) =====
    private Dictionary<string, bool> formSections = new()
    {
        { "identity", true },
        { "combat", false },
        { "stats", false },
        { "defenses", false },
        { "lore", false },
        { "resources", false },
        { "spellcasting", false }
    };

    // Reset stato UI a ogni apertura del form: il genitore crea un nuovo editDraft (nuovo riferimento)
    // a ogni OpenCreateForm/OpenEditForm. Riproduce ciò che prima facevano OpenEditForm + ResetFormSections.
    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(Draft, _lastDraft))
        {
            _lastDraft = Draft;

            foreach (var key in formSections.Keys.ToList())
                formSections[key] = key == "identity";

            // Custom se la classe/razza non è presente nel catalogo (stesso criterio di OpenEditForm).
            isClassCustom = !string.IsNullOrEmpty(Draft.Class)
                && Classes.All(c => !string.Equals(c.Name, Draft.Class, StringComparison.Ordinal));
            isRaceCustom = !string.IsNullOrEmpty(Draft.Race)
                && Races.All(r => !string.Equals(r.Name, Draft.Race, StringComparison.Ordinal));
        }
    }

    private void ToggleFormSection(string key)
    {
        if (formSections.ContainsKey(key))
            formSections[key] = !formSections[key];
    }

    // Info classe/razza selezionata nel form (sostituiscono i vecchi @{ } inline,
    // non ammessi dentro i blocchi @if dell'accordion).
    private CharacterClass? SelectedClassInfo =>
        (!isClassCustom && !string.IsNullOrEmpty(Draft.Class))
            ? Classes.FirstOrDefault(c => c.Name == Draft.Class)
            : null;

    private Race? SelectedRaceInfo =>
        (!isRaceCustom && !string.IsNullOrEmpty(Draft.Race))
            ? Races.FirstOrDefault(r => r.Name == Draft.Race)
            : null;

    private string CurrentRaceSelection =>
        isRaceCustom ? CustomOptionValue : (Draft.Race ?? string.Empty);

    private string CurrentClassSelection =>
        isClassCustom ? CustomOptionValue : (Draft.Class ?? string.Empty);

    private void OnRaceSelectionChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        if (val == CustomOptionValue)
        {
            isRaceCustom = true;
            Draft.Race = string.Empty;
        }
        else
        {
            isRaceCustom = false;
            Draft.Race = val;
        }
    }

    private void OnClassSelectionChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        if (val == CustomOptionValue)
        {
            isClassCustom = true;
            Draft.Class = string.Empty;
        }
        else
        {
            isClassCustom = false;
            Draft.Class = val;
        }
    }

    private static string FormatRaceBonuses(Race race)
    {
        var parts = new List<string>();
        void Add(int val, string label)
        {
            if (val != 0) parts.Add($"{(val > 0 ? "+" : "")}{val} {label}");
        }
        Add(race.StrBonus, "FOR");
        Add(race.DexBonus, "DES");
        Add(race.ConBonus, "COS");
        Add(race.IntBonus, "INT");
        Add(race.WisBonus, "SAG");
        Add(race.ChaBonus, "CAR");
        return parts.Count > 0 ? string.Join(", ", parts) : "nessuno";
    }

    // ===== Slot incantesimo del form (GetSpellSlotMax/Used e SetSpellSlotUsed vengono da CharacterView) =====

    private static void SetSpellSlotMax(Character c, int level, int v)
    {
        switch (level)
        {
            case 1: c.SpellSlots1Max = v; break;
            case 2: c.SpellSlots2Max = v; break;
            case 3: c.SpellSlots3Max = v; break;
            case 4: c.SpellSlots4Max = v; break;
            case 5: c.SpellSlots5Max = v; break;
            case 6: c.SpellSlots6Max = v; break;
            case 7: c.SpellSlots7Max = v; break;
            case 8: c.SpellSlots8Max = v; break;
            case 9: c.SpellSlots9Max = v; break;
        }
    }

    // Handler input slot del form: parsa il valore, clamp 0..9, scrive sul draft.
    private void OnSpellSlotMaxChanged(int level, ChangeEventArgs e)
    {
        var v = ParseSlotInput(e.Value);
        SetSpellSlotMax(Draft, level, v);
    }

    private void OnSpellSlotUsedChanged(int level, ChangeEventArgs e)
    {
        var v = ParseSlotInput(e.Value);
        SetSpellSlotUsed(Draft, level, v);
    }

    private static int ParseSlotInput(object? raw)
    {
        var s = raw?.ToString();
        return int.TryParse(s, out var n) ? Math.Clamp(n, 0, 9) : 0;
    }
}
