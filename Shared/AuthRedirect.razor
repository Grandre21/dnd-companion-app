@inject AuthStateService AuthState
@inject SupabaseService SupabaseService
@inject NavigationManager Navigation

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // GetClientAsync ora esegue tutto il bootstrap della sessione (init + LoadSession +
        // eventuale processing del ritorno OAuth). Dopo questo await la sessione è risolta.
        await SupabaseService.GetClientAsync();

        if (!await AuthState.IsLoggedInAsync())
        {
            Navigation.NavigateTo("login", forceLoad: false, replace: true);
        }
    }
}
