@page "/combat"
@using DndCompanion.Models
@implements IDisposable
@inject ICombatStateRepository CombatStateRepository
@inject ICharacterRepository CharacterRepository
@inject IMonsterRepository MonsterRepository
@inject CurrentUserService CurrentUser
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ConfirmService Confirm

<PageTitle>Combattimento - D&amp;D Companion</PageTitle>

<div class="combat-container">
    <header class="page-header">
        <button type="button" class="back-btn" @onclick='() => Navigation.NavigateTo("")'>
            ← Home
        </button>
        <h1 class="page-title">Tracker Iniziativa</h1>
    </header>

    <DbErrorBanner Message="@errorMessage" OnDismiss="@(() => errorMessage = null)" />

    @if (combatants.Count > 0)
    {
        <div class="round-indicator">
            <div class="round-label">Round <strong>@roundNumber</strong></div>
            @if (CurrentCombatant is not null)
            {
                <div class="current-turn">
                    Turno di <strong>@CurrentCombatant.Name</strong>
                </div>
            }
        </div>
    }
    else if (!CurrentUser.IsMaster)
    {
        <div class="info-banner">
            Nessun combattimento in corso. Il Master non ha ancora avviato l'iniziativa.
        </div>
    }

    @if (CurrentUser.IsMaster)
    {
        <div class="add-form">
            <div class="form-title">Aggiungi combattente</div>
            <div class="form-grid">
                <div class="field field-full">
                    <label>Nome</label>
                    <input type="text" class="input" maxlength="60"
                           placeholder="PG, mostro, PNG..."
                           @bind="newDraft.Name" @bind:event="oninput" />
                </div>
                <div class="field">
                    <label>Iniziativa</label>
                    <input type="number" class="input" @bind="newDraft.Initiative" />
                </div>
                <div class="field">
                    <label>PF attuali</label>
                    <input type="number" class="input" min="0" @bind="newDraft.CurrentHp" />
                </div>
                <div class="field field-full">
                    <label>PF massimi</label>
                    <input type="number" class="input" min="1" @bind="newDraft.MaxHp" />
                </div>
            </div>
            <button type="button" class="add-btn" @onclick="AddCombatant">
                + Aggiungi
            </button>
        </div>

        <div class="master-controls">
            <button type="button" class="ctrl-btn" @onclick="ImportCharactersAsync" disabled="@isImporting">
                @(isImporting ? "Importazione..." : "📥 Importa personaggi")
            </button>
            <button type="button" class="ctrl-btn" @onclick="ToggleMonsterImportAsync" disabled="@isImporting">
                👹 Importa mostri
            </button>
            <button type="button" class="ctrl-btn" @onclick="SortByInitiative" disabled="@(combatants.Count == 0)">
                ↕ Ordina per iniziativa
            </button>
            <button type="button" class="ctrl-btn ctrl-danger" @onclick="NewCombatAsync" disabled="@(combatants.Count == 0)">
                🗑 Nuovo combattimento
            </button>
        </div>

        @if (showMonsterImport)
        {
            <div class="add-form monster-import">
                <div class="form-title">Importa mostri</div>
                @if (isLoadingMonsters)
                {
                    <LoadingSpinner Text="Caricamento mostri..." />
                }
                else if (campaignMonsters.Count == 0)
                {
                    <div class="mi-empty">Nessun mostro nella campagna.</div>
                }
                else
                {
                    @foreach (var m in campaignMonsters)
                    {
                        <div class="mi-row">
                            <span class="mi-name">@m.Name</span>
                            <span class="mi-hp">PF @CombatImport.ParseLeadingHp(m.HitPoints)</span>
                            <div class="mi-stepper">
                                <button type="button" class="hp-btn hp-minus" aria-label="Meno"
                                        @onclick="() => AdjustQty(m.Id, -1)" disabled="@(GetQty(m.Id) == 0)">−</button>
                                <span class="mi-qty">@GetQty(m.Id)</span>
                                <button type="button" class="hp-btn hp-plus" aria-label="Più"
                                        @onclick="() => AdjustQty(m.Id, 1)">+</button>
                            </div>
                        </div>
                    }
                    <button type="button" class="add-btn" @onclick="AddSelectedMonstersAsync"
                            disabled="@(TotalMonsterQty == 0 || isImporting)">
                        @(isImporting ? "Aggiunta..." : $"Aggiungi {TotalMonsterQty} combattenti")
                    </button>
                }
            </div>
        }
    }

    <div class="combatants-list">
        @if (combatants.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">⚔️</div>
                @if (CurrentUser.IsMaster)
                {
                    <p class="empty-text">Nessun combattente. Aggiungili dal form qui sopra o importa i personaggi dal database.</p>
                }
                else
                {
                    <p class="empty-text">In attesa del Master...</p>
                }
            </div>
        }
        else
        {
            @for (var i = 0; i < combatants.Count; i++)
            {
                var c = combatants[i];
                var isCurrent = i == currentTurnIndex;
                var isDefeated = c.CurrentHp <= 0;
                var pos = i + 1;
                <div class="combatant-row @(isCurrent ? "current" : "") @(isDefeated ? "defeated" : "")">
                    <div class="pos">@pos</div>

                    @if (CurrentUser.IsMaster)
                    {
                        <input type="number" class="init-input" @bind="c.Initiative" @bind:event="onchange" />
                    }
                    else
                    {
                        <div class="init-badge">@c.Initiative</div>
                    }

                    <div class="combatant-main">
                        <div class="combatant-name">@c.Name</div>
                        <div class="hp-display">
                            PF <strong>@c.CurrentHp</strong> / @c.MaxHp
                        </div>
                    </div>

                    @if (CurrentUser.IsMaster)
                    {
                        <div class="hp-btns">
                            <button type="button" class="hp-btn hp-minus" aria-label="Diminuisci PF"
                                    @onclick="() => AdjustHp(c, -1)">
                                −
                            </button>
                            <button type="button" class="hp-btn hp-plus" aria-label="Aumenta PF"
                                    @onclick="() => AdjustHp(c, 1)">
                                +
                            </button>
                        </div>
                        <button type="button" class="remove-btn" title="Rimuovi" aria-label="Rimuovi combattente"
                                @onclick="() => RemoveCombatant(c.Id)">
                            ✕
                        </button>
                    }
                </div>
            }
        }
    </div>

    @if (CurrentUser.IsMaster && combatants.Count > 0)
    {
        <div class="turn-controls">
            <button type="button" class="reset-btn" @onclick="ResetRound" title="Torna al Round 1">
                ⟲ Round 1
            </button>
            <button type="button" class="next-turn-btn" @onclick="NextTurn">
                Prossimo Turno →
            </button>
        </div>
    }
</div>

@code {
    private readonly List<Combatant> combatants = new();
    private int currentTurnIndex;
    private int roundNumber = 1;
    private bool isImporting;
    private string? errorMessage;
    private CancellationTokenSource? pollCts;

    private Combatant newDraft = new() { CurrentHp = 10, MaxHp = 10 };

    // ----- Import mostri -----
    private bool showMonsterImport;
    private bool monstersLoaded;
    private bool isLoadingMonsters;
    private List<Monster> campaignMonsters = new();
    private readonly Dictionary<string, int> monsterQty = new();

    private int TotalMonsterQty => monsterQty.Values.Sum();
    private int GetQty(string monsterId) => monsterQty.TryGetValue(monsterId, out var q) ? q : 0;

    private Combatant? CurrentCombatant =>
        (combatants.Count > 0 && currentTurnIndex < combatants.Count)
            ? combatants[currentTurnIndex]
            : null;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.EnsureLoadedAsync();

        await LoadCombatStateAsync();

        // I giocatori (non Master) non modificano lo stato: lo aggiornano via polling leggero
        // mentre sono sulla pagina, così vedono i cambi di turno/PF decisi dal Master.
        if (!CurrentUser.IsMaster)
            StartPolling();
    }

    // ----- Stato condiviso (combat_state) -----

    private async Task LoadCombatStateAsync()
    {
        if (string.IsNullOrEmpty(CurrentUser.CampaignId)) return;
        try
        {
            var state = await CombatStateRepository.GetCombatStateAsync(CurrentUser.CampaignId);
            combatants.Clear();
            if (state is not null)
            {
                combatants.AddRange(state.Combatants);
                roundNumber = state.RoundNumber;
                currentTurnIndex = state.CurrentTurnIndex < combatants.Count ? state.CurrentTurnIndex : 0;
            }
            else
            {
                currentTurnIndex = 0;
                roundNumber = 1;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento combattimento: {ex.Message}";
        }
    }

    // Master: persiste lo stato corrente; i giocatori lo rileggono via polling.
    private async Task SaveCombatStateAsync()
    {
        if (!CurrentUser.IsMaster || string.IsNullOrEmpty(CurrentUser.CampaignId)) return;
        try
        {
            await CombatStateRepository.SaveCombatStateAsync(new CombatState
            {
                CampaignId = CurrentUser.CampaignId,
                Combatants = combatants.ToList(),
                CurrentTurnIndex = currentTurnIndex,
                RoundNumber = roundNumber
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio combattimento: {ex.Message}";
        }
    }

    private void StartPolling()
    {
        pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(pollCts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(4000, ct);
                if (ct.IsCancellationRequested) break;
                await LoadCombatStateAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Polling fermato in Dispose: normale.
        }
    }

    // ----- Azioni del Master (ognuna persiste lo stato) -----

    private async Task AddCombatant()
    {
        if (!CurrentUser.IsMaster) return;

        if (string.IsNullOrWhiteSpace(newDraft.Name))
        {
            errorMessage = "Inserisci il nome del combattente";
            return;
        }
        if (newDraft.MaxHp < 1) newDraft.MaxHp = 1;
        if (newDraft.CurrentHp < 0) newDraft.CurrentHp = 0;
        if (newDraft.CurrentHp > newDraft.MaxHp) newDraft.CurrentHp = newDraft.MaxHp;

        combatants.Add(new Combatant
        {
            Name = newDraft.Name.Trim(),
            Initiative = newDraft.Initiative,
            CurrentHp = newDraft.CurrentHp,
            MaxHp = newDraft.MaxHp
        });

        SortByInitiativeInternal();
        newDraft = new Combatant { CurrentHp = 10, MaxHp = 10 };
        errorMessage = null;
        await SaveCombatStateAsync();
    }

    private async Task ImportCharactersAsync()
    {
        if (!CurrentUser.IsMaster) return;

        isImporting = true;
        errorMessage = null;
        try
        {
            if (string.IsNullOrEmpty(CurrentUser.CampaignId))
            {
                errorMessage = "Nessuna campagna attiva.";
                return;
            }

            var characters = await CharacterRepository.GetCharactersForCampaignAsync(CurrentUser.CampaignId);
            if (characters.Count == 0)
            {
                errorMessage = "Nessun personaggio nella campagna da importare.";
                return;
            }

            foreach (var ch in characters)
            {
                combatants.Add(new Combatant
                {
                    Name = ch.Name,
                    Initiative = 0,
                    CurrentHp = ch.HitPoints,
                    MaxHp = ch.MaxHitPoints
                });
            }
            await SaveCombatStateAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore importazione: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task ToggleMonsterImportAsync()
    {
        if (!CurrentUser.IsMaster) return;
        showMonsterImport = !showMonsterImport;
        if (showMonsterImport && !monstersLoaded)
            await LoadCampaignMonstersAsync();
    }

    private async Task LoadCampaignMonstersAsync()
    {
        if (string.IsNullOrEmpty(CurrentUser.CampaignId)) return;
        isLoadingMonsters = true;
        errorMessage = null;
        try
        {
            campaignMonsters = await MonsterRepository.GetMonstersForCampaignAsync(CurrentUser.CampaignId);
            monsterQty.Clear();
            monstersLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento mostri: {ex.Message}";
        }
        finally
        {
            isLoadingMonsters = false;
        }
    }

    private void AdjustQty(string monsterId, int delta)
        => monsterQty[monsterId] = Math.Max(0, GetQty(monsterId) + delta);

    private async Task AddSelectedMonstersAsync()
    {
        if (!CurrentUser.IsMaster) return;
        isImporting = true;
        errorMessage = null;
        try
        {
            foreach (var m in campaignMonsters)
            {
                var qty = GetQty(m.Id);
                if (qty > 0) combatants.AddRange(CombatImport.FromMonster(m, qty));
            }
            await SaveCombatStateAsync();
            showMonsterImport = false;
            monsterQty.Clear();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore importazione mostri: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task RemoveCombatant(string id)
    {
        if (!CurrentUser.IsMaster) return;

        var currentId = CurrentCombatant?.Id;
        var idx = combatants.FindIndex(c => c.Id == id);
        if (idx < 0) return;

        combatants.RemoveAt(idx);

        if (combatants.Count == 0)
        {
            currentTurnIndex = 0;
        }
        else if (currentId is not null && currentId != id)
        {
            var newIdx = combatants.FindIndex(c => c.Id == currentId);
            if (newIdx >= 0) currentTurnIndex = newIdx;
            else if (currentTurnIndex >= combatants.Count) currentTurnIndex = 0;
        }
        else if (currentTurnIndex >= combatants.Count)
        {
            currentTurnIndex = 0;
        }

        await SaveCombatStateAsync();
    }

    private async Task AdjustHp(Combatant c, int delta)
    {
        if (!CurrentUser.IsMaster) return;
        c.CurrentHp = Math.Clamp(c.CurrentHp + delta, 0, c.MaxHp);
        await SaveCombatStateAsync();
    }

    private async Task NextTurn()
    {
        if (!CurrentUser.IsMaster || combatants.Count == 0) return;

        currentTurnIndex++;
        if (currentTurnIndex >= combatants.Count)
        {
            currentTurnIndex = 0;
            roundNumber++;
        }
        await SaveCombatStateAsync();
    }

    private async Task ResetRound()
    {
        if (!CurrentUser.IsMaster) return;
        currentTurnIndex = 0;
        roundNumber = 1;
        await SaveCombatStateAsync();
    }

    private async Task SortByInitiative()
    {
        if (!CurrentUser.IsMaster || combatants.Count == 0) return;
        SortByInitiativeInternal();
        await SaveCombatStateAsync();
    }

    private void SortByInitiativeInternal()
    {
        if (combatants.Count == 0) return;

        var currentId = CurrentCombatant?.Id;
        var sorted = combatants
            .OrderByDescending(c => c.Initiative)
            .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        combatants.Clear();
        combatants.AddRange(sorted);

        if (currentId is not null)
        {
            var newIdx = combatants.FindIndex(c => c.Id == currentId);
            if (newIdx >= 0) currentTurnIndex = newIdx;
        }
    }

    private async Task NewCombatAsync()
    {
        if (!CurrentUser.IsMaster) return;

        if (combatants.Count > 0)
        {
            var confirmed = await Confirm.ShowAsync(
                "Iniziare un nuovo combattimento? La lista corrente verrà cancellata.");
            if (!confirmed) return;
        }

        combatants.Clear();
        currentTurnIndex = 0;
        roundNumber = 1;
        errorMessage = null;
        await SaveCombatStateAsync();
    }

    public void Dispose()
    {
        pollCts?.Cancel();
        pollCts?.Dispose();
    }
}
