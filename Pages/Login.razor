@page "/login"
@layout LoginLayout
@using DndCompanion.Services
@inject SupabaseService SupabaseService
@inject NavigationManager Navigation

<PageTitle>Accesso - D&amp;D Companion</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h1>D&amp;D Companion</h1>
        <p class="subtitle">Accedi per gestire le tue campagne</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error">@errorMessage</div>
        }

        <div class="actions">
            <button type="button" class="btn primary" @onclick="SignInWithGoogle" disabled="@isBusy">
                @(isBusy ? "Attendere..." : "Accedi con Google")
            </button>
        </div>
    </div>
</div>

@code {
    private string? errorMessage;
    private bool isBusy;

    private async Task SignInWithGoogle()
    {
        isBusy = true;
        errorMessage = null;
        try
        {
            var client = await SupabaseService.GetClientAsync();

            // RedirectTo dinamico: BaseUri include già il base path /dnd-companion-app/
            // in produzione (GitHub Pages) e l'host locale in sviluppo.
            var state = await client.Auth.SignIn(
                Supabase.Gotrue.Constants.Provider.Google,
                new Supabase.Gotrue.SignInOptions { RedirectTo = Navigation.BaseUri });

            // La libreria NON redirige da sola in WASM: naviga il browser all'URL
            // OAuth di Google restituito in ProviderAuthState.Uri (forceLoad obbligatorio).
            Navigation.NavigateTo(state.Uri.ToString(), forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore di accesso: {ex.Message}";
            isBusy = false;
        }
    }
}
