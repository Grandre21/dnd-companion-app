                                    <p class="field-hint">Imposta gli slot massimi secondo la tabella della tua classe. Gli slot usati si gestiscono durante la sessione dal tab Magic della scheda.</p>
                                }
                            </div>
                        }
                    </div>

                </div>

                <div class="form-actions">
                    <button type="button" class="primary-btn" @onclick="SaveFormAsync" disabled="@isBusy">
                        @(isBusy ? "Salvataggio..." : "Salva")
                    </button>
                    <button type="button" class="secondary-btn" @onclick="CancelForm" disabled="@isBusy">
                        Annulla
                    </button>
                </div>
            </div>
            break;
    }

    @* Creazione personaggio: per OGNI membro (player e master), in ogni vista tranne il form. *@
    @if (mode is ViewMode.List or ViewMode.Empty or ViewMode.Detail)
    {
        <button type="button" class="fab" @onclick="OpenCreateForm" title="Nuovo personaggio">
            +
        </button>
    }
</div>

@code {
    private enum ViewMode { Loading, Empty, List, Detail, Form }

    private ViewMode mode = ViewMode.Loading;
    private List<Character> characters = new();
    private Character? selected;
    private Character editDraft = new();
    private List<Race> races = new();
    private List<CharacterClass> classes = new();
    private bool isRaceCustom;
    private bool isClassCustom;
    private const string CustomOptionValue = "__custom__";

    private List<InventoryItem> inventoryItems = new();
    private InventoryItem newItemDraft = new();
    private bool isAddingItem;
    private string? expandedItemId;
    private bool isLoadingInventory;
    private bool isSavingInventory;

    // ===== Incantesimi del PG (tab Magic) =====
    // allSpells = catalogo globale (caricato una sola volta, in cache).
    // selectedCharacterSpells = righe character_spells del PG corrente.
    private List<Spell> allSpells = new();
    private bool spellsLoaded;
    private List<CharacterSpell> selectedCharacterSpells = new();
    private List<CharacterSpellView> characterSpellsForDisplay = new();

    private record CharacterSpellView(CharacterSpell Entry, Spell Spell);

    // JOIN logico in memoria CharacterSpell -> Spell; scarta gli orfani (spell
    // rimosso dal catalogo globale ma ancora referenziato dal PG).
    private void RebuildSpellDisplay()
    {
        var views = new List<CharacterSpellView>();
        foreach (var cs in selectedCharacterSpells)
        {
            var spell = allSpells.FirstOrDefault(s => s.Id == cs.SpellId);
            if (spell is null) continue; // orfano: spell rimosso dal catalogo globale, scarta
            views.Add(new CharacterSpellView(cs, spell));
        }
        characterSpellsForDisplay = views;
    }

    // Le armi (Value "weapon") vengono mostrate nella sezione Combattimento,
    // non nella lista Inventario. Le altre voci usano Value == Label.
    private static readonly (string Value, string Label)[] ItemTypeOptions =
    {
        ("Altro", "Altro"),
        ("weapon", "Arma"),
        ("Armatura", "Armatura"),
        ("Pozione", "Pozione"),
        ("Pergamena", "Pergamena"),
        ("Strumento", "Strumento"),
        ("Tesoro", "Tesoro")
    };

    // ===== Navigazione a tab della vista detail =====
    // valori: combat | stats | bio | items | magic
    private string activeTab = "combat";

    // ===== Sezioni a fisarmonica del form (apertura/chiusura) =====
    private Dictionary<string, bool> formSections = new()
    {
        { "identity", true },
        { "combat", false },
        { "stats", false },
        { "defenses", false },
        { "lore", false },
        { "resources", false },
        { "spellcasting", false }
    };

    private void ToggleFormSection(string key)
    {
        if (formSections.ContainsKey(key))
            formSections[key] = !formSections[key];
    }

    private void ResetFormSections()
    {
        foreach (var key in formSections.Keys.ToList())
            formSections[key] = key == "identity";
    }

    // Info classe/razza selezionata nel form (sostituiscono i vecchi @{ } inline,
    // non ammessi dentro i blocchi @if dell'accordion).
    private CharacterClass? SelectedClassInfo =>
        (!isClassCustom && !string.IsNullOrEmpty(editDraft.Class))
            ? classes.FirstOrDefault(c => c.Name == editDraft.Class)
            : null;

    private Race? SelectedRaceInfo =>
        (!isRaceCustom && !string.IsNullOrEmpty(editDraft.Race))
            ? races.FirstOrDefault(r => r.Name == editDraft.Race)
            : null;

    private string? userId;
    private string? campaignId;
    private bool isMaster;

    private bool isBusy;
    private bool isEditingMoney;
    private string? errorMessage;

    private bool CanEditInventory =>
        selected is not null && (isMaster || selected.OwnerId == userId);

    private bool CanEdit =>
        selected is not null && (isMaster || selected.OwnerId == userId);

    private double TotalInventoryWeight =>
        inventoryItems.Sum(i => (i.Weight ?? 0) * i.Quantity);

    private static string SpellAbilityShort(string? a)
    {
        if (string.IsNullOrWhiteSpace(a)) return string.Empty;
        var t = a.Trim();
        return (t.Length <= 3 ? t : t[..3]).ToUpperInvariant();
    }

