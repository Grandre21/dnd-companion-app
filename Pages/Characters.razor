    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CampaignState.InitializeAsync();
            userId = await AuthState.GetUserIdAsync();
            isMaster = CampaignState.IsMaster;
            campaignId = CampaignState.ActiveCampaignId;

            if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(campaignId))
            {
                // Non loggato (AuthRedirect interviene) o nessuna campagna attiva.
                mode = ViewMode.Empty;
                return;
            }

            // Tutti i personaggi della campagna; il permesso di modifica è per-personaggio (CanEdit).
            var charsFetch = SupabaseService.GetCharactersForCampaignAsync(campaignId);
            var racesTask = SupabaseService.GetRacesForCampaignAsync(campaignId);
            var classesTask = SupabaseService.GetClassesForCampaignAsync(campaignId);

            await Task.WhenAll(charsFetch, racesTask, classesTask);

            characters = charsFetch.Result;
            races = racesTask.Result;
            classes = classesTask.Result;

            await UpdateModeFromCharactersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento: {ex.Message}";
            mode = ViewMode.Empty;
        }
    }

    private async Task UpdateModeFromCharactersAsync()
    {
        if (isMaster)
        {
            mode = ViewMode.List;
        }
        else if (characters.Count == 0)
        {
            mode = ViewMode.Empty;
        }
        else if (characters.Count == 1)
        {
            await OpenDetailAsync(characters[0]);
        }
        else
        {
            mode = ViewMode.List;
        }
    }

    private async Task OpenDetailAsync(Character c)
    {
        selected = c;
        mode = ViewMode.Detail;
        activeTab = "combat";
        expandedItemId = null;
        isAddingItem = false;
        isEditingMoney = false;
        await LoadInventoryAsync(c.Id);
        await LoadSpellsForSelectedAsync(c);
    }

    // Carica catalogo globale (una sola volta) + incantesimi del PG, solo per gli incantatori.
    private async Task LoadSpellsForSelectedAsync(Character c)
    {
        selectedCharacterSpells = new();
        characterSpellsForDisplay = new();

        if (string.IsNullOrWhiteSpace(c.SpellcastingAbility))
            return;

        try
        {
            var charSpellsTask = SupabaseService.GetCharacterSpellsAsync(c.Id);
            if (!spellsLoaded)
            {
                var allTask = SupabaseService.GetSpellsForCampaignAsync(campaignId ?? string.Empty);
                await Task.WhenAll(allTask, charSpellsTask);
                allSpells = allTask.Result;
                spellsLoaded = true;
            }
            else
            {
                await charSpellsTask;
            }
            selectedCharacterSpells = charSpellsTask.Result;
            RebuildSpellDisplay();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento incantesimi: {ex.Message}";
            selectedCharacterSpells = new();
            characterSpellsForDisplay = new();
        }
    }

