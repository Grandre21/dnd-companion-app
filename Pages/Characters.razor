    // Stringa compatta delle sole valute > 0, in ordine di valore decrescente (MP>MO>ME>MA>MR).
    private string FormatMoney()
    {
        if (selected is null) return "Nessuna moneta";
        var parts = new List<string>();
        if (selected.PlatinumPieces > 0) parts.Add($"{selected.PlatinumPieces} MP");
        if (selected.GoldPieces > 0) parts.Add($"{selected.GoldPieces} MO");
        if (selected.ElectrumPieces > 0) parts.Add($"{selected.ElectrumPieces} ME");
        if (selected.SilverPieces > 0) parts.Add($"{selected.SilverPieces} MA");
        if (selected.CopperPieces > 0) parts.Add($"{selected.CopperPieces} MR");
        return parts.Count > 0 ? string.Join(" · ", parts) : "Nessuna moneta";
    }

