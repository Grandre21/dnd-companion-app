@page "/characters"
@using DndCompanion.Models
@inject ICharacterRepository CharacterRepository
@inject IRaceRepository RaceRepository
@inject IClassRepository ClassRepository
@inject ISpellRepository SpellRepository
@inject IInventoryRepository InventoryRepository
@inject AuthStateService AuthState
@inject CampaignStateService CampaignState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ToastService Toasts
@inject ConfirmService Confirm

<PageTitle>Personaggi - D&amp;D Companion</PageTitle>

<div class="characters-container">
    @if (selected == null)
    {
        <header class="page-header">
            <button type="button" class="back-btn" @onclick='() => Navigation.NavigateTo("")'>
                ← Home
            </button>
            <h1 class="page-title">Personaggi</h1>
        </header>
    }

    <DbErrorBanner Message="@errorMessage" OnDismiss="@(() => errorMessage = null)" />

    @switch (mode)
    {
        case ViewMode.Loading:
            <LoadingSpinner />
            break;

        case ViewMode.Empty:
            <div class="empty-state">
                <div class="empty-icon">🗡️</div>
                <p class="empty-text">Non hai ancora un personaggio.</p>
                <button type="button" class="primary-btn" @onclick="OpenCreateForm">
                    Crea Personaggio
                </button>
            </div>
            break;

        case ViewMode.List:
            <div class="list-view">
                @if (characters.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-icon">🗡️</div>
                        <p class="empty-text">Nessun personaggio in questa campagna.</p>
                        <button type="button" class="primary-btn" @onclick="OpenCreateForm">
                            Crea Personaggio
                        </button>
                    </div>
                }
                else
                {
                    <div class="char-list">
                        @foreach (var c in characters)
                        {
                            <button type="button" class="list-card" @onclick="() => OpenDetailAsync(c)">
                                <div class="list-name">@c.Name</div>
                                <div class="list-meta">Liv @c.Level · @c.Class · @c.Race</div>
                                <div class="list-hp">PF @c.HitPoints / @c.MaxHitPoints</div>
                            </button>
                        }
                    </div>
                }
            </div>
            break;

        case ViewMode.Detail when selected is not null:
            <div class="char-sheet">
                @* ===== Header unificato ===== *@
                <div class="character-header">
                    <button class="header-btn back-btn" @onclick="GoBack" aria-label="Indietro">←</button>
                    <div class="character-title">
                        <h1 class="character-name">@selected.Name</h1>
                        <p class="character-subtitle">
                            Liv @selected.Level · @selected.Class@(string.IsNullOrWhiteSpace(selected.Subclass) ? "" : $" {selected.Subclass}") · @selected.Race
                        </p>
                    </div>
                    @if (CanEdit)
                    {
                        <button class="header-btn edit-btn" @onclick="StartEdit" aria-label="Modifica">✎</button>
                    }
                </div>

                @* ===== Tab bar ===== *@
                <div class="tab-bar">
                    <button class="tab-item @(activeTab == "combat" ? "active" : "")" @onclick='() => activeTab = "combat"'>
                        <span class="tab-icon">⚔</span>
                        <span class="tab-label">Combat</span>
                    </button>
                    <button class="tab-item @(activeTab == "stats" ? "active" : "")" @onclick='() => activeTab = "stats"'>
                        <span class="tab-icon">📊</span>
                        <span class="tab-label">Stats</span>
                    </button>
                    <button class="tab-item @(activeTab == "bio" ? "active" : "")" @onclick='() => activeTab = "bio"'>
                        <span class="tab-icon">👤</span>
                        <span class="tab-label">Bio</span>
                    </button>
                    <button class="tab-item @(activeTab == "items" ? "active" : "")" @onclick='() => activeTab = "items"'>
                        <span class="tab-icon">🎒</span>
                        <span class="tab-label">Items</span>
                    </button>
                    @if (!string.IsNullOrWhiteSpace(selected.SpellcastingAbility))
                    {
                        <button class="tab-item @(activeTab == "magic" ? "active" : "")" @onclick='() => activeTab = "magic"'>
                            <span class="tab-icon">✨</span>
                            <span class="tab-label">Magic</span>
                        </button>
                    }
                </div>

                <div class="tab-content">

                @* ===================== TAB COMBAT ===================== *@
                @if (activeTab == "combat")
                {
                    <CharacterCombatTab Character="@selected" CanEdit="@CanEdit" OnChanged="@SaveCharacterAsync"
                                        Weapons="@inventoryItems.Where(i => string.Equals(i.ItemType, "weapon", StringComparison.OrdinalIgnoreCase)).ToList()" />
                }

                @* ===================== TAB STATS ===================== *@
                @if (activeTab == "stats")
                {
                    <CharacterStatsTab Character="@selected" CanEdit="@CanEdit" OnChanged="@SaveCharacterAsync" />
                }

                @* ===================== TAB BIO ===================== *@
                @if (activeTab == "bio")
                {
                    <CharacterBioTab Character="@selected" OnSaveNotes="@SaveNotesAsync" />
                }

                @* ===================== TAB ITEMS ===================== *@
                @if (activeTab == "items")
                {
                    <CharacterItemsTab Character="@selected" CanEdit="@CanEdit" Items="@inventoryItems"
                                       IsLoading="@isLoadingInventory" OnChanged="@SaveCharacterAsync"
                                       OnInventoryChanged="@ReloadInventoryAsync" OnError="@SetError" />
                }

                @* ===================== TAB MAGIC ===================== *@
                @if (activeTab == "magic" && !string.IsNullOrWhiteSpace(selected.SpellcastingAbility))
                {
                    <CharacterMagicTab Character="@selected" CanEdit="@CanEdit" OnChanged="@SaveCharacterAsync"
                                       AllSpells="@allSpells" OnError="@SetError" />
                }

                </div>
            </div>
            break;

        case ViewMode.Form:
            <CharacterEditForm Draft="@editDraft" Classes="@classes" Races="@races"
                               IsBusy="@isBusy" OnSave="@SaveFormAsync" OnCancel="@CancelForm" />
            break;
    }

    @* Creazione personaggio: per OGNI membro (player e master), in ogni vista tranne il form. *@
    @if (mode is ViewMode.List or ViewMode.Empty or ViewMode.Detail)
    {
        <button type="button" class="fab" @onclick="OpenCreateForm" title="Nuovo personaggio">
            +
        </button>
    }
</div>

@code {
    private enum ViewMode { Loading, Empty, List, Detail, Form }

    private ViewMode mode = ViewMode.Loading;
    private List<Character> characters = new();
    private Character? selected;
    private Character editDraft = new();
    private List<Race> races = new();
    private List<CharacterClass> classes = new();

    private List<InventoryItem> inventoryItems = new();
    private bool isLoadingInventory;

    // Catalogo globale incantesimi (caricato una sola volta, in cache); passato a CharacterMagicTab.
    // Gli incantesimi del singolo PG li gestisce CharacterMagicTab.
    private List<Spell> allSpells = new();
    private bool spellsLoaded;

    // ===== Navigazione a tab della vista detail =====
    // valori: combat | stats | bio | items | magic
    private string activeTab = "combat";

    private string? userId;
    private string? campaignId;
    private bool isMaster;

    private bool isBusy;
    private string? errorMessage;

    private bool CanEdit =>
        selected is not null && (isMaster || selected.OwnerId == userId);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CampaignState.InitializeAsync();
            userId = await AuthState.GetUserIdAsync();
            isMaster = CampaignState.IsMaster;
            campaignId = CampaignState.ActiveCampaignId;

            if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(campaignId))
            {
                // Non loggato (AuthRedirect interviene) o nessuna campagna attiva.
                mode = ViewMode.Empty;
                return;
            }

            // Tutti i personaggi della campagna; il permesso di modifica è per-personaggio (CanEdit).
            var charsFetch = CharacterRepository.GetCharactersForCampaignAsync(campaignId);
            var racesTask = RaceRepository.GetRacesForCampaignAsync(campaignId);
            var classesTask = ClassRepository.GetClassesForCampaignAsync(campaignId);

            await Task.WhenAll(charsFetch, racesTask, classesTask);

            characters = charsFetch.Result;
            races = racesTask.Result;
            classes = classesTask.Result;

            await UpdateModeFromCharactersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento: {ex.Message}";
            mode = ViewMode.Empty;
        }
    }

    private async Task UpdateModeFromCharactersAsync()
    {
        if (isMaster)
        {
            mode = ViewMode.List;
        }
        else if (characters.Count == 0)
        {
            mode = ViewMode.Empty;
        }
        else if (characters.Count == 1)
        {
            await OpenDetailAsync(characters[0]);
        }
        else
        {
            mode = ViewMode.List;
        }
    }

    private async Task OpenDetailAsync(Character c)
    {
        selected = c;
        mode = ViewMode.Detail;
        activeTab = "combat";
        await LoadInventoryAsync(c.Id);
        await EnsureSpellCatalogAsync();
    }

    // Carica catalogo globale (una sola volta) + incantesimi del PG, solo per gli incantatori.
    // Carica una sola volta il catalogo globale incantesimi (per il SpellPicker di CharacterMagicTab e per il
    // form). Gli incantesimi del singolo PG li carica il componente Magic in OnParametersSet.
    private async Task EnsureSpellCatalogAsync()
    {
        if (spellsLoaded) return;
        try
        {
            allSpells = await SpellRepository.GetSpellsForCampaignAsync(campaignId ?? string.Empty);
            spellsLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento catalogo incantesimi: {ex.Message}";
        }
    }

    private void GoBack()
    {
        selected = null;
        BackToListOrEmpty();
    }

    private void StartEdit() => OpenEditForm();

    private async Task LoadInventoryAsync(string characterId)
    {
        isLoadingInventory = true;
        try
        {
            inventoryItems = await InventoryRepository.GetInventoryForCharacterAsync(characterId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento inventario: {ex.Message}";
            inventoryItems = new();
        }
        finally
        {
            isLoadingInventory = false;
        }
    }

    // Ricarica l'inventario dopo una modifica strutturale di CharacterItemsTab (add/delete),
    // così anche le armi mostrate nel tab Combat restano allineate.
    private async Task ReloadInventoryAsync()
    {
        if (selected is not null) await LoadInventoryAsync(selected.Id);
    }

    private void SetError(string? message) => errorMessage = message;

    private void BackToListOrEmpty()
    {
        if (isMaster || characters.Count > 1)
        {
            mode = ViewMode.List;
        }
        else if (characters.Count == 0)
        {
            mode = ViewMode.Empty;
        }
        else
        {
            Navigation.NavigateTo("");
        }
    }

    private void OpenCreateForm()
    {
        editDraft = new Character
        {
            OwnerId = userId ?? string.Empty,
            CampaignId = campaignId ?? string.Empty,
            Level = 1,
            ArmorClass = 10,
            HitPoints = 10,
            MaxHitPoints = 10,
            Strength = 10,
            Dexterity = 10,
            Constitution = 10,
            Intelligence = 10,
            Wisdom = 10,
            Charisma = 10
        };
        mode = ViewMode.Form;
    }

    private void OpenEditForm()
    {
        if (selected is null) return;
        editDraft = CloneCharacter(selected);
        mode = ViewMode.Form;
    }

    private void CancelForm()
    {
        if (selected is not null)
        {
            mode = ViewMode.Detail;
        }
        else if (isMaster || characters.Count > 0)
        {
            mode = ViewMode.List;
        }
        else
        {
            mode = ViewMode.Empty;
        }
    }

    private async Task SaveFormAsync()
    {
        if (string.IsNullOrWhiteSpace(editDraft.Name))
        {
            errorMessage = "Il nome è obbligatorio";
            return;
        }
        if (editDraft.MaxHitPoints < 1)
        {
            errorMessage = "Gli HP massimi devono essere almeno 1";
            return;
        }
        if (editDraft.HitPoints > editDraft.MaxHitPoints)
        {
            editDraft.HitPoints = editDraft.MaxHitPoints;
        }

        NormalizeDraft();

        isBusy = true;
        errorMessage = null;
        try
        {
            Character? saved;
            if (string.IsNullOrEmpty(editDraft.Id))
            {
                editDraft.OwnerId = userId ?? string.Empty;
                editDraft.CampaignId = campaignId ?? string.Empty;
                saved = await CharacterRepository.CreateCharacterAsync(editDraft);
            }
            else
            {
                saved = await CharacterRepository.UpdateCharacterAsync(editDraft);
            }

            if (saved is null)
            {
                errorMessage = "Il server non ha restituito il personaggio salvato.";
                return;
            }

            var idx = characters.FindIndex(c => c.Id == saved.Id);
            if (idx >= 0) characters[idx] = saved;
            else characters.Add(saved);

            Toasts.ShowSuccess("Personaggio salvato");
            await OpenDetailAsync(saved);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    // Trim su tutti i testi; vuoti -> null per i campi nullable. Clamp dei numerici.
    private void NormalizeDraft()
    {
        static string? Clean(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

        editDraft.Name = editDraft.Name?.Trim() ?? string.Empty;
        editDraft.Class = editDraft.Class?.Trim() ?? string.Empty;
        editDraft.Race = editDraft.Race?.Trim() ?? string.Empty;
        editDraft.Size = string.IsNullOrWhiteSpace(editDraft.Size) ? "Media" : editDraft.Size.Trim();

        editDraft.Subclass = Clean(editDraft.Subclass);
        editDraft.Background = Clean(editDraft.Background);
        editDraft.Alignment = Clean(editDraft.Alignment);
        editDraft.Appearance = Clean(editDraft.Appearance);
        editDraft.Backstory = Clean(editDraft.Backstory);
        editDraft.Languages = Clean(editDraft.Languages);
        editDraft.HitDiceMax = Clean(editDraft.HitDiceMax);
        editDraft.SpeciesTraits = Clean(editDraft.SpeciesTraits);
        editDraft.ClassFeatures = Clean(editDraft.ClassFeatures);
        editDraft.Feats = Clean(editDraft.Feats);
        editDraft.Notes = Clean(editDraft.Notes);
        editDraft.AttunedItem1 = Clean(editDraft.AttunedItem1);
        editDraft.AttunedItem2 = Clean(editDraft.AttunedItem2);
        editDraft.AttunedItem3 = Clean(editDraft.AttunedItem3);
        editDraft.DamageResistances = Clean(editDraft.DamageResistances);
        editDraft.DamageImmunities = Clean(editDraft.DamageImmunities);
        editDraft.DamageVulnerabilities = Clean(editDraft.DamageVulnerabilities);
        editDraft.ConditionImmunities = Clean(editDraft.ConditionImmunities);
        editDraft.SpellcastingAbility = Clean(editDraft.SpellcastingAbility);

        editDraft.Level = Math.Clamp(editDraft.Level, 1, 20);
        editDraft.ArmorClass = Math.Max(0, editDraft.ArmorClass);
        editDraft.HitPoints = Math.Max(0, editDraft.HitPoints);
        editDraft.TempHitPoints = Math.Max(0, editDraft.TempHitPoints);
        editDraft.Speed = Math.Max(0, editDraft.Speed);
        editDraft.HitDiceSpent = Math.Max(0, editDraft.HitDiceSpent);
        editDraft.ExperiencePoints = Math.Max(0, editDraft.ExperiencePoints);
        editDraft.CopperPieces = Math.Max(0, editDraft.CopperPieces);
        editDraft.SilverPieces = Math.Max(0, editDraft.SilverPieces);
        editDraft.ElectrumPieces = Math.Max(0, editDraft.ElectrumPieces);
        editDraft.GoldPieces = Math.Max(0, editDraft.GoldPieces);
        editDraft.PlatinumPieces = Math.Max(0, editDraft.PlatinumPieces);
    }

    // Persistenza delle note (invocata da CharacterBioTab via OnSaveNotes); il draft e il flag di
    // salvataggio vivono nel componente.
    private async Task SaveNotesAsync(string text)
    {
        if (selected is null) return;

        var previous = selected.Notes;
        selected.Notes = text;
        errorMessage = null;
        try
        {
            var saved = await CharacterRepository.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                selected.Notes = saved.Notes;
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            selected.Notes = previous;
            errorMessage = $"Errore salvataggio note: {ex.Message}";
        }
    }

    private async Task SaveCharacterAsync()
    {
        if (selected is null) return;

        errorMessage = null;
        try
        {
            var saved = await CharacterRepository.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio caratteristiche: {ex.Message}";
        }
    }

    private void SyncListFromSelected()
    {
        if (selected is null) return;
        var idx = characters.FindIndex(c => c.Id == selected.Id);
        if (idx >= 0) characters[idx] = selected;
    }


    // Copia profonda di TUTTI i campi: il form di modifica deve fare round-trip
    // completo, altrimenti salvando si azzerano i campi non clonati.
    private static Character CloneCharacter(Character c) => new()
    {
        Id = c.Id,
        OwnerId = c.OwnerId,
        CampaignId = c.CampaignId,
        Name = c.Name,
        Class = c.Class,
        Race = c.Race,
        Level = c.Level,
        HitPoints = c.HitPoints,
        MaxHitPoints = c.MaxHitPoints,
        ArmorClass = c.ArmorClass,
        Strength = c.Strength,
        Dexterity = c.Dexterity,
        Constitution = c.Constitution,
        Intelligence = c.Intelligence,
        Wisdom = c.Wisdom,
        Charisma = c.Charisma,
        Notes = c.Notes,
        CreatedAt = c.CreatedAt,

        // Identità estesa
        Background = c.Background,
        Subclass = c.Subclass,
        Alignment = c.Alignment,
        ExperiencePoints = c.ExperiencePoints,
        Size = c.Size,
        Speed = c.Speed,
        Appearance = c.Appearance,
        Backstory = c.Backstory,
        Languages = c.Languages,

        // HP avanzati e stato in combattimento
        TempHitPoints = c.TempHitPoints,
        HitDiceMax = c.HitDiceMax,
        HitDiceSpent = c.HitDiceSpent,
        DeathSaveSuccesses = c.DeathSaveSuccesses,
        DeathSaveFailures = c.DeathSaveFailures,
        HeroicInspiration = c.HeroicInspiration,

        // Competenze tiri salvezza
        ProfSaveStrength = c.ProfSaveStrength,
        ProfSaveDexterity = c.ProfSaveDexterity,
        ProfSaveConstitution = c.ProfSaveConstitution,
        ProfSaveIntelligence = c.ProfSaveIntelligence,
        ProfSaveWisdom = c.ProfSaveWisdom,
        ProfSaveCharisma = c.ProfSaveCharisma,

        // Skill: competenza
        ProfAthletics = c.ProfAthletics,
        ProfAcrobatics = c.ProfAcrobatics,
        ProfSleightOfHand = c.ProfSleightOfHand,
        ProfStealth = c.ProfStealth,
        ProfArcana = c.ProfArcana,
        ProfHistory = c.ProfHistory,
        ProfInvestigation = c.ProfInvestigation,
        ProfNature = c.ProfNature,
        ProfReligion = c.ProfReligion,
        ProfAnimalHandling = c.ProfAnimalHandling,
        ProfInsight = c.ProfInsight,
        ProfMedicine = c.ProfMedicine,
        ProfPerception = c.ProfPerception,
        ProfSurvival = c.ProfSurvival,
        ProfDeception = c.ProfDeception,
        ProfIntimidation = c.ProfIntimidation,
        ProfPerformance = c.ProfPerformance,
        ProfPersuasion = c.ProfPersuasion,

        // Skill: expertise
        ExpAthletics = c.ExpAthletics,
        ExpAcrobatics = c.ExpAcrobatics,
        ExpSleightOfHand = c.ExpSleightOfHand,
        ExpStealth = c.ExpStealth,
        ExpArcana = c.ExpArcana,
        ExpHistory = c.ExpHistory,
        ExpInvestigation = c.ExpInvestigation,
        ExpNature = c.ExpNature,
        ExpReligion = c.ExpReligion,
        ExpAnimalHandling = c.ExpAnimalHandling,
        ExpInsight = c.ExpInsight,
        ExpMedicine = c.ExpMedicine,
        ExpPerception = c.ExpPerception,
        ExpSurvival = c.ExpSurvival,
        ExpDeception = c.ExpDeception,
        ExpIntimidation = c.ExpIntimidation,
        ExpPerformance = c.ExpPerformance,
        ExpPersuasion = c.ExpPersuasion,

        // Tratti, talenti, privilegi
        SpeciesTraits = c.SpeciesTraits,
        ClassFeatures = c.ClassFeatures,
        Feats = c.Feats,

        // Denari
        CopperPieces = c.CopperPieces,
        SilverPieces = c.SilverPieces,
        ElectrumPieces = c.ElectrumPieces,
        GoldPieces = c.GoldPieces,
        PlatinumPieces = c.PlatinumPieces,

        // Sintonia oggetti magici
        AttunedItem1 = c.AttunedItem1,
        AttunedItem2 = c.AttunedItem2,
        AttunedItem3 = c.AttunedItem3,

        // Difese
        DamageResistances = c.DamageResistances,
        DamageImmunities = c.DamageImmunities,
        DamageVulnerabilities = c.DamageVulnerabilities,
        ConditionImmunities = c.ConditionImmunities,

        // Incantatore
        SpellcastingAbility = c.SpellcastingAbility,
        SpellSlots1Max = c.SpellSlots1Max, SpellSlots1Used = c.SpellSlots1Used,
        SpellSlots2Max = c.SpellSlots2Max, SpellSlots2Used = c.SpellSlots2Used,
        SpellSlots3Max = c.SpellSlots3Max, SpellSlots3Used = c.SpellSlots3Used,
        SpellSlots4Max = c.SpellSlots4Max, SpellSlots4Used = c.SpellSlots4Used,
        SpellSlots5Max = c.SpellSlots5Max, SpellSlots5Used = c.SpellSlots5Used,
        SpellSlots6Max = c.SpellSlots6Max, SpellSlots6Used = c.SpellSlots6Used,
        SpellSlots7Max = c.SpellSlots7Max, SpellSlots7Used = c.SpellSlots7Used,
        SpellSlots8Max = c.SpellSlots8Max, SpellSlots8Used = c.SpellSlots8Used,
        SpellSlots9Max = c.SpellSlots9Max, SpellSlots9Used = c.SpellSlots9Used
    };

}
