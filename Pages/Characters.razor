    private async Task SaveFormAsync()
    {
        if (string.IsNullOrWhiteSpace(editDraft.Name))
        {
            errorMessage = "Il nome è obbligatorio";
            return;
        }
        if (editDraft.MaxHitPoints < 1)
        {
            errorMessage = "Gli HP massimi devono essere almeno 1";
            return;
        }
        if (editDraft.HitPoints > editDraft.MaxHitPoints)
        {
            editDraft.HitPoints = editDraft.MaxHitPoints;
        }

        NormalizeDraft();

        isBusy = true;
        errorMessage = null;
        try
        {
            Character? saved;
            if (string.IsNullOrEmpty(editDraft.Id))
            {
                editDraft.OwnerId = userId ?? string.Empty;
                editDraft.CampaignId = campaignId ?? string.Empty;
                saved = await SupabaseService.CreateCharacterAsync(editDraft);
            }
            else
            {
                saved = await SupabaseService.UpdateCharacterAsync(editDraft);
            }

            if (saved is null)
            {
                errorMessage = "Il server non ha restituito il personaggio salvato.";
                return;
            }

            var idx = characters.FindIndex(c => c.Id == saved.Id);
            if (idx >= 0) characters[idx] = saved;
            else characters.Add(saved);

            Toasts.ShowSuccess("Personaggio salvato");
            await OpenDetailAsync(saved);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    // Trim su tutti i testi; vuoti -> null per i campi nullable. Clamp dei numerici.
    private void NormalizeDraft()
    {
        static string? Clean(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

        editDraft.Name = editDraft.Name?.Trim() ?? string.Empty;
        editDraft.Class = editDraft.Class?.Trim() ?? string.Empty;
        editDraft.Race = editDraft.Race?.Trim() ?? string.Empty;
        editDraft.Size = string.IsNullOrWhiteSpace(editDraft.Size) ? "Media" : editDraft.Size.Trim();

        editDraft.Subclass = Clean(editDraft.Subclass);
        editDraft.Background = Clean(editDraft.Background);
        editDraft.Alignment = Clean(editDraft.Alignment);
        editDraft.Appearance = Clean(editDraft.Appearance);
        editDraft.Backstory = Clean(editDraft.Backstory);
        editDraft.Languages = Clean(editDraft.Languages);
        editDraft.HitDiceMax = Clean(editDraft.HitDiceMax);
        editDraft.SpeciesTraits = Clean(editDraft.SpeciesTraits);
        editDraft.ClassFeatures = Clean(editDraft.ClassFeatures);
        editDraft.Feats = Clean(editDraft.Feats);
        editDraft.Notes = Clean(editDraft.Notes);
        editDraft.AttunedItem1 = Clean(editDraft.AttunedItem1);
        editDraft.AttunedItem2 = Clean(editDraft.AttunedItem2);
        editDraft.AttunedItem3 = Clean(editDraft.AttunedItem3);
        editDraft.DamageResistances = Clean(editDraft.DamageResistances);
        editDraft.DamageImmunities = Clean(editDraft.DamageImmunities);
        editDraft.DamageVulnerabilities = Clean(editDraft.DamageVulnerabilities);
        editDraft.ConditionImmunities = Clean(editDraft.ConditionImmunities);
        editDraft.SpellcastingAbility = Clean(editDraft.SpellcastingAbility);

        editDraft.Level = Math.Clamp(editDraft.Level, 1, 20);
        editDraft.ArmorClass = Math.Max(0, editDraft.ArmorClass);
        editDraft.HitPoints = Math.Max(0, editDraft.HitPoints);
        editDraft.TempHitPoints = Math.Max(0, editDraft.TempHitPoints);
        editDraft.Speed = Math.Max(0, editDraft.Speed);
        editDraft.HitDiceSpent = Math.Max(0, editDraft.HitDiceSpent);
        editDraft.ExperiencePoints = Math.Max(0, editDraft.ExperiencePoints);
        editDraft.CopperPieces = Math.Max(0, editDraft.CopperPieces);
        editDraft.SilverPieces = Math.Max(0, editDraft.SilverPieces);
        editDraft.ElectrumPieces = Math.Max(0, editDraft.ElectrumPieces);
        editDraft.GoldPieces = Math.Max(0, editDraft.GoldPieces);
        editDraft.PlatinumPieces = Math.Max(0, editDraft.PlatinumPieces);
    }

    // Persistenza delle note (invocata da CharacterBioTab via OnSaveNotes); il draft e il flag di
    // salvataggio vivono nel componente.
    private async Task SaveNotesAsync(string text)
    {
        if (selected is null) return;

        var previous = selected.Notes;
        selected.Notes = text;
        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                selected.Notes = saved.Notes;
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            selected.Notes = previous;
            errorMessage = $"Errore salvataggio note: {ex.Message}";
        }
    }

    private async Task SaveCharacterAsync()
    {
        if (selected is null) return;

        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio caratteristiche: {ex.Message}";
        }
    }

    private async Task ToggleSpellSlot(int level, int index)
    {
        if (selected is null || !CanEdit) return;
        var max = GetSpellSlotMax(selected, level);
        if (max <= 0) return;
        var used = GetSpellSlotUsed(selected, level);
        var available = max - used;
        // Click su uno slot disponibile: spende fino a quel punto (ne restano index-1).
        // Click su uno slot già speso: lo ripristina (ne restano index).
        var newUsed = index <= available ? max - (index - 1) : max - index;
        newUsed = Math.Clamp(newUsed, 0, max);
        if (newUsed == used) return;
        SetSpellSlotUsed(selected, level, newUsed);
        await SaveCharacterAsync();
    }

    private async Task SetAttunementAsync(int slot, string? raw)
    {
        if (selected is null || !CanEdit) return;
        var val = string.IsNullOrWhiteSpace(raw) ? null : raw.Trim();
        switch (slot)
        {
            case 1: selected.AttunedItem1 = val; break;
            case 2: selected.AttunedItem2 = val; break;
            case 3: selected.AttunedItem3 = val; break;
            default: return;
        }
        await SaveCharacterAsync();
    }

    private void SyncListFromSelected()
    {
        if (selected is null) return;
        var idx = characters.FindIndex(c => c.Id == selected.Id);
        if (idx >= 0) characters[idx] = selected;
    }

