    private async Task AddSpellToCharacter(Spell spell)
    {
        if (selected is null || !CanEdit) return;
        var entry = new CharacterSpell
        {
            CharacterId = selected.Id,
            SpellId = spell.Id,
            IsPrepared = spell.Level == 0 // i trucchetti sono auto-preparati
        };
        try
        {
            var saved = await SupabaseService.AddSpellToCharacterAsync(entry);
            if (saved is not null)
            {
                selectedCharacterSpells.Add(saved);
                RebuildSpellDisplay();
            }
            else
            {
                errorMessage = "Impossibile aggiungere l'incantesimo.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore aggiunta incantesimo: {ex.Message}";
        }
    }

    private async Task TogglePrepared(CharacterSpell entry)
    {
        // entry.IsPrepared è già stato invertito dal componente figlio.
        try
        {
            var ok = await SupabaseService.UpdateCharacterSpellAsync(entry);
            if (!ok)
            {
                entry.IsPrepared = !entry.IsPrepared; // revert
                errorMessage = "Impossibile aggiornare lo stato preparato.";
            }
        }
        catch (Exception ex)
        {
            entry.IsPrepared = !entry.IsPrepared; // revert
            errorMessage = $"Errore aggiornamento incantesimo: {ex.Message}";
        }
    }

    private async Task RemoveSpellFromCharacter(CharacterSpell entry)
    {
        try
        {
            var ok = await SupabaseService.RemoveCharacterSpellAsync(entry.Id);
            if (ok)
            {
                selectedCharacterSpells.Remove(entry);
                RebuildSpellDisplay();
            }
            else
            {
                errorMessage = "Impossibile rimuovere l'incantesimo.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore rimozione incantesimo: {ex.Message}";
        }
    }

