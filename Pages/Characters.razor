@page "/characters"
@using DndCompanion.Models
@inject SupabaseService SupabaseService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Personaggi - D&amp;D Companion</PageTitle>

<div class="characters-container">
    <header class="page-header">
        <button type="button" class="back-btn" @onclick='() => Navigation.NavigateTo("")'>
            ← Home
        </button>
        <h1 class="page-title">Personaggi</h1>
    </header>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-banner" @onclick="() => errorMessage = null">@errorMessage</div>
    }

    @switch (mode)
    {
        case ViewMode.Loading:
            <div class="state-message">Caricamento...</div>
            break;

        case ViewMode.Empty:
            <div class="empty-state">
                <div class="empty-icon">🗡️</div>
                <p class="empty-text">Non hai ancora un personaggio.</p>
                <button type="button" class="primary-btn" @onclick="OpenCreateForm">
                    Crea Personaggio
                </button>
            </div>
            break;

        case ViewMode.List:
            <div class="list-view">
                @if (characters.Count == 0)
                {
                    <div class="state-message">Nessun personaggio trovato.</div>
                }
                else
                {
                    <div class="char-list">
                        @foreach (var c in characters)
                        {
                            <button type="button" class="list-card" @onclick="() => OpenDetailAsync(c)">
                                <div class="list-name">@c.Name</div>
                                <div class="list-meta">Liv @c.Level · @c.Class · @c.Race</div>
                                <div class="list-hp">PF @c.HitPoints / @c.MaxHitPoints</div>
                            </button>
                        }
                    </div>
                }
            </div>
            break;

        case ViewMode.Detail when selected is not null:
            <div class="char-sheet">
                <div class="sheet-top">
                    <button type="button" class="back-link" @onclick="BackToListOrEmpty">← Indietro</button>
                    <button type="button" class="edit-btn" @onclick="OpenEditForm">Modifica</button>
                </div>

                @* ===== 1. HEADER IDENTITÀ ===== *@
                <div class="identity-header">
                    <h2 class="char-name">@selected.Name</h2>
                    <p class="identity-line">
                        Liv @selected.Level <span class="id-sep">·</span>
                        @selected.Class@(string.IsNullOrWhiteSpace(selected.Subclass) ? "" : " " + selected.Subclass)
                        <span class="id-sep">·</span> @selected.Race
                    </p>
                    @if (!string.IsNullOrWhiteSpace(selected.Background))
                    {
                        <p class="identity-bg">Background: @selected.Background</p>
                    }
                </div>

                @* ===== 2. VITAL SIGNS ===== *@
                <div class="vitals-card">
                    <div class="vitals-hp">
                        <div class="section-label">Punti Ferita</div>
                        <div class="hp-controls">
                            <button type="button" class="hp-btn hp-minus"
                                    @onclick="() => AdjustHpAsync(-1)"
                                    disabled="@(!CanEdit || isSavingHp || selected.HitPoints <= 0)">
                                −
                            </button>
                            <div class="hp-value">
                                <span class="hp-current">@selected.HitPoints</span>
                                <span class="hp-sep">/</span>
                                <span class="hp-max">@selected.MaxHitPoints</span>
                                @if (selected.TempHitPoints > 0)
                                {
                                    <span class="hp-temp" title="Punti ferita temporanei">+@selected.TempHitPoints</span>
                                }
                            </div>
                            <button type="button" class="hp-btn hp-plus"
                                    @onclick="() => AdjustHpAsync(1)"
                                    disabled="@(!CanEdit || isSavingHp || selected.HitPoints >= selected.MaxHitPoints)">
                                +
                            </button>
                        </div>

                        @if (ShowDeathSaves)
                        {
                            <div class="death-saves">
                                <div class="ds-group">
                                    <span class="ds-label ds-ok">Successi</span>
                                    <div class="ds-dots">
                                        @for (var i = 1; i <= 3; i++)
                                        {
                                            var filled = selected.DeathSaveSuccesses >= i;
                                            <span class="ds-dot ds-dot-ok @(filled ? "on" : "")"
                                                  @onclick="CycleDeathSuccessAsync"></span>
                                        }
                                    </div>
                                </div>
                                <div class="ds-group">
                                    <span class="ds-label ds-ko">Fallimenti</span>
                                    <div class="ds-dots">
                                        @for (var i = 1; i <= 3; i++)
                                        {
                                            var filled = selected.DeathSaveFailures >= i;
                                            <span class="ds-dot ds-dot-ko @(filled ? "on" : "")"
                                                  @onclick="CycleDeathFailureAsync"></span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="vitals-grid">
                        <div class="mini-stat">
                            <span class="ms-label">CA</span>
                            <span class="ms-value">@selected.ArmorClass</span>
                        </div>
                        <div class="mini-stat">
                            <span class="ms-label">INI</span>
                            <span class="ms-value">@FmtBonus(CharacterCalculations.GetInitiative(selected))</span>
                        </div>
                        <div class="mini-stat">
                            <span class="ms-label">VEL</span>
                            <span class="ms-value">@selected.Speed</span>
                        </div>
                        <div class="mini-stat">
                            <span class="ms-label">Perc Pass</span>
                            <span class="ms-value">@CharacterCalculations.GetPassivePerception(selected)</span>
                        </div>
                        <div class="mini-stat">
                            <span class="ms-label">BC</span>
                            <span class="ms-value">@FmtBonus(CharacterCalculations.GetProficiencyBonus(selected.Level))</span>
                        </div>
                        <div class="mini-stat">
                            <span class="ms-label">Taglia</span>
                            <span class="ms-value ms-value-sm">@selected.Size</span>
                        </div>
                    </div>
                </div>

                @* ===== 3. CARATTERISTICHE ===== *@
                <div class="stats-section">
                    <div class="section-label">Caratteristiche</div>
                    <div class="stats-grid">
                        <StatCard Ability="AbilityType.Strength"     Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Dexterity"    Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Constitution" Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Intelligence" Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Wisdom"       Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Charisma"     Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                    </div>
                </div>

                @* ===== 4. COMBATTIMENTO ===== *@
                <div class="sheet-card">
                    <div class="section-label">Combattimento</div>

                    <div class="cbt-sub">
                        <div class="cbt-sub-title">Armi</div>
                        @{
                            var weapons = inventoryItems.Where(IsWeapon).ToList();
                        }
                        @if (weapons.Count == 0)
                        {
                            <div class="cbt-empty">Nessuna arma equipaggiata</div>
                        }
                        else
                        {
                            <div class="cbt-weapons">
                                @foreach (var w in weapons)
                                {
                                    <div class="cbt-weapon">
                                        <span class="cbt-w-name">@w.Name</span>
                                        <span class="cbt-w-atk">@(string.IsNullOrWhiteSpace(w.AttackBonus) ? "—" : w.AttackBonus)</span>
                                        <span class="cbt-w-dmg">@FormatDamage(w)</span>
                                        @if (!string.IsNullOrWhiteSpace(w.AttackNotes))
                                        {
                                            <span class="cbt-w-notes">@w.AttackNotes</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (HasDefenses)
                    {
                        <div class="cbt-sub">
                            <div class="cbt-sub-title">Resistenze / Immunità</div>
                            @if (!string.IsNullOrWhiteSpace(selected.DamageResistances))
                            {
                                <div class="def-row def-res"><strong>Resistenze:</strong> @selected.DamageResistances</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.DamageImmunities))
                            {
                                <div class="def-row def-imm"><strong>Immunità:</strong> @selected.DamageImmunities</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.DamageVulnerabilities))
                            {
                                <div class="def-row def-vuln"><strong>Vulnerabilità:</strong> @selected.DamageVulnerabilities</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.ConditionImmunities))
                            {
                                <div class="def-row def-cond"><strong>Imm. condizioni:</strong> @selected.ConditionImmunities</div>
                            }
                        </div>
                    }

                    <div class="cbt-sub">
                        <div class="hi-row">
                            <span class="hi-label">Ispirazione Eroica</span>
                            <span class="hi-toggle @(selected.HeroicInspiration ? "on" : "") @(CanEdit ? "" : "ro")"
                                  @onclick="ToggleHeroicInspirationAsync"></span>
                        </div>
                    </div>
                </div>

                @* ===== 5. RISORSE ===== *@
                <div class="sheet-card">
                    <button type="button" class="collapse-head" @onclick="() => isResourcesExpanded = !isResourcesExpanded">
                        <span class="ch-title">@(isResourcesExpanded ? "▾" : "▸") Risorse</span>
                        <span class="ch-summary">@ResourcesSummary</span>
                    </button>

                    @if (isResourcesExpanded)
                    {
                        <div class="collapse-body">
                            <div class="res-row">
                                <span class="res-label">Dadi Vita @HitDiceTypeLabel()</span>
                                <div class="res-ctrl">
                                    @if (CanEdit)
                                    {
                                        <button type="button" class="mini-btn"
                                                @onclick="() => AdjustHitDiceSpentAsync(-1)"
                                                disabled="@(selected.HitDiceSpent <= 0)">−</button>
                                    }
                                    <span class="res-value">@selected.HitDiceSpent/@HitDiceTotal() usati</span>
                                    @if (CanEdit)
                                    {
                                        <button type="button" class="mini-btn"
                                                @onclick="() => AdjustHitDiceSpentAsync(1)"
                                                disabled="@(selected.HitDiceSpent >= HitDiceTotal())">+</button>
                                    }
                                </div>
                            </div>

                            <div class="coins-grid">
                                @foreach (var coin in CoinDefs)
                                {
                                    <div class="coin" title="@coin.FullName">
                                        <span class="coin-label">@coin.Code</span>
                                        <span class="coin-value">@coin.Get(selected)</span>
                                        @if (CanEdit)
                                        {
                                            <div class="coin-ctrl">
                                                <button type="button" class="mini-btn"
                                                        @onclick="() => AdjustCoinAsync(coin.Code, -1)"
                                                        disabled="@(coin.Get(selected) <= 0)">−</button>
                                                <button type="button" class="mini-btn"
                                                        @onclick="() => AdjustCoinAsync(coin.Code, 1)">+</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="attune-block">
                                <div class="cbt-sub-title">Sintonie</div>
                                @for (var slot = 1; slot <= 3; slot++)
                                {
                                    var n = slot;
                                    var val = AttunementValue(n);
                                    <div class="attune-row">
                                        @if (CanEdit)
                                        {
                                            <input class="attune-input" maxlength="80"
                                                   placeholder="(slot libero)"
                                                   value="@val"
                                                   @onchange="e => SetAttunementAsync(n, e.Value?.ToString())" />
                                        }
                                        else if (!string.IsNullOrWhiteSpace(val))
                                        {
                                            <span class="attune-text">✦ @val</span>
                                        }
                                        else
                                        {
                                            <span class="attune-empty">(slot libero)</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* ===== 6. CONOSCENZE ===== *@
                @if (HasKnowledge)
                {
                    <div class="sheet-card">
                        <button type="button" class="collapse-head" @onclick="() => isKnowledgeExpanded = !isKnowledgeExpanded">
                            <span class="ch-title">@(isKnowledgeExpanded ? "▾" : "▸") Conoscenze</span>
                            <span class="ch-summary">@KnowledgeSummary</span>
                        </button>

                        @if (isKnowledgeExpanded)
                        {
                            <div class="collapse-body">
                                <div class="know-block">
                                    <div class="cbt-sub-title">Lingue</div>
                                    <div class="know-text">@(string.IsNullOrWhiteSpace(selected.Languages) ? "—" : selected.Languages)</div>
                                </div>
                                <div class="know-block">
                                    <div class="cbt-sub-title">Tratti della specie</div>
                                    <div class="know-text">@(string.IsNullOrWhiteSpace(selected.SpeciesTraits) ? "—" : selected.SpeciesTraits)</div>
                                </div>
                                <div class="know-block">
                                    <div class="cbt-sub-title">Privilegi di classe</div>
                                    <div class="know-text">@(string.IsNullOrWhiteSpace(selected.ClassFeatures) ? "—" : selected.ClassFeatures)</div>
                                </div>
                                <div class="know-block">
                                    <div class="cbt-sub-title">Talenti</div>
                                    <div class="know-text">@(string.IsNullOrWhiteSpace(selected.Feats) ? "—" : selected.Feats)</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @* ===== 7. STORIA E ASPETTO + NOTE ===== *@
                @if (!string.IsNullOrWhiteSpace(selected.Backstory) || !string.IsNullOrWhiteSpace(selected.Appearance))
                {
                    <div class="sheet-card">
                        <div class="section-label">Storia e Aspetto</div>
                        @if (!string.IsNullOrWhiteSpace(selected.Backstory))
                        {
                            <div class="know-block">
                                <div class="cbt-sub-title">Storia</div>
                                <div class="know-text">@selected.Backstory</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(selected.Appearance))
                        {
                            <div class="know-block">
                                <div class="cbt-sub-title">Aspetto</div>
                                <div class="know-text">@selected.Appearance</div>
                            </div>
                        }
                    </div>
                }

                <div class="notes-section">
                    <div class="section-label">Note</div>
                    <textarea class="notes-textarea" rows="5" @bind="notesDraft"
                              placeholder="Equipaggiamento, background, obiettivi..."></textarea>
                    <button type="button" class="small-btn"
                            @onclick="SaveNotesAsync"
                            disabled="@(isSavingNotes || notesDraft == (selected.Notes ?? string.Empty))">
                        @(isSavingNotes ? "Salvataggio..." : "Salva note")
                    </button>
                </div>

                @* ===== 8. INVENTARIO ===== *@
                @{
                    var invDisplay = inventoryItems.Where(i => !IsWeapon(i)).ToList();
                }
                <div class="inventory-section">
                    <div class="section-label">Inventario</div>

                    <div class="inv-summary">
                        <span class="inv-summary-item">
                            <strong>@invDisplay.Sum(i => i.Quantity)</strong> oggetti
                        </span>
                        <span class="inv-summary-sep">·</span>
                        <span class="inv-summary-item">
                            Peso totale: <strong>@FormatWeight(TotalInventoryWeight)</strong>
                        </span>
                    </div>

                    @if (CanEditInventory)
                    {
                        @if (!isAddingItem)
                        {
                            <button type="button" class="inv-add-btn" @onclick="OpenAddItemForm">
                                + Aggiungi oggetto
                            </button>
                        }
                        else
                        {
                            <div class="inv-form">
                                <div class="inv-form-grid">
                                    <div class="field field-full">
                                        <label>Nome</label>
                                        <input type="text" class="input" maxlength="80"
                                               placeholder="Nome dell'oggetto"
                                               @bind="newItemDraft.Name" />
                                    </div>

                                    <div class="field">
                                        <label>Quantità</label>
                                        <input type="number" class="input" min="1" @bind="newItemDraft.Quantity" />
                                    </div>

                                    <div class="field">
                                        <label>Peso</label>
                                        <input type="number" class="input" step="0.1" min="0"
                                               @bind="newItemDraft.Weight" />
                                    </div>

                                    <div class="field field-full">
                                        <label>Tipo</label>
                                        <select class="input" @bind="newItemDraft.ItemType">
                                            @foreach (var o in ItemTypeOptions)
                                            {
                                                <option value="@o.Value">@o.Label</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="field field-full">
                                        <label>Descrizione (opzionale)</label>
                                        <textarea class="input" rows="3"
                                                  @bind="newItemDraft.Description"></textarea>
                                    </div>
                                </div>

                                <div class="inv-form-actions">
                                    <button type="button" class="primary-btn"
                                            @onclick="SaveNewItemAsync"
                                            disabled="@isSavingInventory">
                                        @(isSavingInventory ? "Salvataggio..." : "Salva")
                                    </button>
                                    <button type="button" class="secondary-btn"
                                            @onclick="CancelAddItem"
                                            disabled="@isSavingInventory">
                                        Annulla
                                    </button>
                                </div>
                            </div>
                        }
                    }

                    @if (isLoadingInventory)
                    {
                        <div class="inv-loading">Caricamento inventario...</div>
                    }
                    else if (invDisplay.Count == 0)
                    {
                        <div class="inv-empty">Nessun oggetto nell'inventario.</div>
                    }
                    else
                    {
                        <div class="inv-list">
                            @foreach (var item in invDisplay)
                            {
                                var isItemExpanded = expandedItemId == item.Id;
                                <div class="inv-item @(item.IsEquipped ? "equipped" : "")">
                                    <div class="inv-row">
                                        <button type="button" class="inv-name-btn"
                                                @onclick="() => ToggleItemExpand(item.Id)">
                                            @if (item.IsEquipped)
                                            {
                                                <span class="eq-icon" title="Equipaggiato">⚔️</span>
                                            }
                                            <span class="inv-name-text">@item.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(item.Description))
                                            {
                                                <span class="inv-exp-icon">@(isItemExpanded ? "▾" : "▸")</span>
                                            }
                                        </button>

                                        @if (CanEditInventory)
                                        {
                                            <div class="qty-controls">
                                                <button type="button" class="qty-btn qty-minus"
                                                        @onclick="() => AdjustQuantityAsync(item, -1)"
                                                        disabled="@isSavingInventory">
                                                    −
                                                </button>
                                                <span class="qty-value">@item.Quantity</span>
                                                <button type="button" class="qty-btn qty-plus"
                                                        @onclick="() => AdjustQuantityAsync(item, 1)"
                                                        disabled="@isSavingInventory">
                                                    +
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="qty-readonly">×@item.Quantity</div>
                                        }
                                    </div>

                                    <div class="inv-meta">
                                        @if (!string.IsNullOrWhiteSpace(item.ItemType))
                                        {
                                            <span class="inv-type-badge">@item.ItemType</span>
                                        }
                                        @if (item.Weight.HasValue)
                                        {
                                            <span class="inv-weight">@FormatWeight(item.Weight.Value * item.Quantity)</span>
                                        }

                                        @if (CanEditInventory)
                                        {
                                            <label class="inv-eq-toggle">
                                                <input type="checkbox" checked="@item.IsEquipped"
                                                       @onchange="@(e => ToggleEquippedAsync(item, (bool)(e.Value ?? false)))"
                                                       disabled="@isSavingInventory" />
                                                <span>Equipaggiato</span>
                                            </label>

                                            <button type="button" class="inv-delete-btn"
                                                    title="Elimina oggetto"
                                                    @onclick="() => DeleteItemAsync(item)"
                                                    disabled="@isSavingInventory">
                                                🗑️
                                            </button>
                                        }
                                    </div>

                                    @if (isItemExpanded && !string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <div class="inv-description">@item.Description</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @* ===== 9. INCANTESIMI (placeholder) ===== *@
                @if (!string.IsNullOrWhiteSpace(selected.SpellcastingAbility))
                {
                    <div class="sheet-card">
                        <div class="section-label">Incantesimi</div>
                        <div class="spell-placeholder">Sezione in arrivo nella prossima fase</div>
                    </div>
                }
            </div>
            break;

        case ViewMode.Form:
            <div class="form-view">
                <div class="sheet-top">
                    <button type="button" class="back-link" @onclick="CancelForm">← Annulla</button>
                </div>

                <h2 class="form-title">
                    @(string.IsNullOrEmpty(editDraft.Id) ? "Nuovo Personaggio" : "Modifica Personaggio")
                </h2>

                <div class="form-grid">
                    <div class="field field-full">
                        <label>Nome</label>
                        <input type="text" class="input" maxlength="64" @bind="editDraft.Name" />
                    </div>

                    <div class="field field-full">
                        <label>Classe</label>
                        <select class="input" value="@CurrentClassSelection" @onchange="OnClassSelectionChanged">
                            <option value="">-- Seleziona --</option>
                            @foreach (var c in classes.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                            <option value="__custom__">Altro (testo libero)</option>
                        </select>
                        @if (isClassCustom)
                        {
                            <input type="text" class="input custom-input" maxlength="40"
                                   placeholder="Scrivi la classe"
                                   @bind="editDraft.Class" @bind:event="oninput" />
                        }
                        @{
                            var selectedClass = (!isClassCustom && !string.IsNullOrEmpty(editDraft.Class))
                                ? classes.FirstOrDefault(c => c.Name == editDraft.Class)
                                : null;
                        }
                        @if (selectedClass is not null)
                        {
                            <div class="info-summary">
                                <strong>Dado vita:</strong> @(string.IsNullOrEmpty(selectedClass.HitDie) ? "—" : selectedClass.HitDie)
                                @if (!string.IsNullOrWhiteSpace(selectedClass.PrimaryAbility))
                                {
                                    <span> · <strong>Abilità primaria:</strong> @selectedClass.PrimaryAbility</span>
                                }
                            </div>
                        }
                    </div>

                    <div class="field field-full">
                        <label>Razza</label>
                        <select class="input" value="@CurrentRaceSelection" @onchange="OnRaceSelectionChanged">
                            <option value="">-- Seleziona --</option>
                            @foreach (var r in races.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@r.Name">@r.Name</option>
                            }
                            <option value="__custom__">Altro (testo libero)</option>
                        </select>
                        @if (isRaceCustom)
                        {
                            <input type="text" class="input custom-input" maxlength="40"
                                   placeholder="Scrivi la razza"
                                   @bind="editDraft.Race" @bind:event="oninput" />
                        }
                        @{
                            var selectedRace = (!isRaceCustom && !string.IsNullOrEmpty(editDraft.Race))
                                ? races.FirstOrDefault(r => r.Name == editDraft.Race)
                                : null;
                        }
                        @if (selectedRace is not null)
                        {
                            <div class="info-summary">
                                <strong>Bonus razziali:</strong> @FormatRaceBonuses(selectedRace)
                                · <strong>Velocità:</strong> @selectedRace.Speed
                            </div>
                        }
                    </div>

                    <div class="field">
                        <label>Livello</label>
                        <input type="number" class="input" min="1" max="20" @bind="editDraft.Level" />
                    </div>

                    <div class="field">
                        <label>CA</label>
                        <input type="number" class="input" min="0" max="40" @bind="editDraft.ArmorClass" />
                    </div>

                    <div class="field">
                        <label>PF Correnti</label>
                        <input type="number" class="input" min="0" @bind="editDraft.HitPoints" />
                    </div>

                    <div class="field">
                        <label>PF Massimi</label>
                        <input type="number" class="input" min="1" @bind="editDraft.MaxHitPoints" />
                    </div>

                    <div class="field-group field-full">
                        <label class="group-label">Caratteristiche</label>
                        <div class="stats-inputs">
                            <div class="field stat-field">
                                <label title="Forza">FOR</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Strength" />
                            </div>
                            <div class="field stat-field">
                                <label title="Destrezza">DES</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Dexterity" />
                            </div>
                            <div class="field stat-field">
                                <label title="Costituzione">COS</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Constitution" />
                            </div>
                            <div class="field stat-field">
                                <label title="Intelligenza">INT</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Intelligence" />
                            </div>
                            <div class="field stat-field">
                                <label title="Saggezza">SAG</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Wisdom" />
                            </div>
                            <div class="field stat-field">
                                <label title="Carisma">CAR</label>
                                <input type="number" class="input" min="1" max="30" @bind="editDraft.Charisma" />
                            </div>
                        </div>
                    </div>

                    <div class="field field-full">
                        <label>Note</label>
                        <textarea class="input" rows="4" @bind="editDraft.Notes"></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="primary-btn" @onclick="SaveFormAsync" disabled="@isBusy">
                        @(isBusy ? "Salvataggio..." : "Salva")
                    </button>
                    <button type="button" class="secondary-btn" @onclick="CancelForm" disabled="@isBusy">
                        Annulla
                    </button>
                </div>
            </div>
            break;
    }
</div>

@code {
    private enum ViewMode { Loading, Empty, List, Detail, Form }

    private ViewMode mode = ViewMode.Loading;
    private List<Character> characters = new();
    private Character? selected;
    private Character editDraft = new();
    private string notesDraft = string.Empty;

    private List<Race> races = new();
    private List<CharacterClass> classes = new();
    private bool isRaceCustom;
    private bool isClassCustom;
    private const string CustomOptionValue = "__custom__";

    private List<InventoryItem> inventoryItems = new();
    private InventoryItem newItemDraft = new();
    private bool isAddingItem;
    private string? expandedItemId;
    private bool isLoadingInventory;
    private bool isSavingInventory;

    // Le armi (Value "weapon") vengono mostrate nella sezione Combattimento,
    // non nella lista Inventario. Le altre voci usano Value == Label.
    private static readonly (string Value, string Label)[] ItemTypeOptions =
    {
        ("Altro", "Altro"),
        ("weapon", "Arma"),
        ("Armatura", "Armatura"),
        ("Pozione", "Pozione"),
        ("Pergamena", "Pergamena"),
        ("Strumento", "Strumento"),
        ("Tesoro", "Tesoro")
    };

    // ===== Stato sezioni collassabili (chiuse di default) =====
    private bool isResourcesExpanded;
    private bool isKnowledgeExpanded;

    private string? playerId;
    private bool isMaster;

    private bool isBusy;
    private bool isSavingHp;
    private bool isSavingNotes;
    private string? errorMessage;

    private bool CanEditInventory =>
        selected is not null && (isMaster || selected.PlayerId == playerId);

    private bool CanEdit =>
        selected is not null && (isMaster || selected.PlayerId == playerId);

    private double TotalInventoryWeight =>
        inventoryItems.Where(i => !IsWeapon(i)).Sum(i => (i.Weight ?? 0) * i.Quantity);

    private static bool IsWeapon(InventoryItem i) =>
        string.Equals(i.ItemType, "weapon", StringComparison.OrdinalIgnoreCase);

    // ===== Vital signs / combattimento =====

    private bool ShowDeathSaves =>
        selected is not null &&
        (selected.HitPoints == 0 || selected.DeathSaveSuccesses > 0 || selected.DeathSaveFailures > 0);

    private bool HasDefenses =>
        selected is not null &&
        (!string.IsNullOrWhiteSpace(selected.DamageResistances) ||
         !string.IsNullOrWhiteSpace(selected.DamageImmunities) ||
         !string.IsNullOrWhiteSpace(selected.DamageVulnerabilities) ||
         !string.IsNullOrWhiteSpace(selected.ConditionImmunities));

    private bool HasKnowledge =>
        selected is not null &&
        (!string.IsNullOrWhiteSpace(selected.Languages) ||
         !string.IsNullOrWhiteSpace(selected.SpeciesTraits) ||
         !string.IsNullOrWhiteSpace(selected.ClassFeatures) ||
         !string.IsNullOrWhiteSpace(selected.Feats));

    private static string FmtBonus(int v) => v >= 0 ? $"+{v}" : v.ToString();

    private static string FormatDamage(InventoryItem w)
    {
        var dmg = (w.Damage ?? string.Empty).Trim();
        var type = (w.DamageType ?? string.Empty).Trim();
        var combined = string.Join(" ", new[] { dmg, type }.Where(s => s.Length > 0));
        return combined.Length == 0 ? "—" : combined;
    }

    // ===== Dadi vita =====

    private int HitDiceTotal()
    {
        if (selected is null || string.IsNullOrWhiteSpace(selected.HitDiceMax)) return 0;
        var total = 0;
        foreach (var block in selected.HitDiceMax.Split('+'))
        {
            var t = block.Trim();
            if (t.Length == 0) continue;
            var countPart = t.Split('d')[0].Trim();
            if (int.TryParse(countPart, out var n)) total += n;
        }
        return total;
    }

    private string HitDiceTypeLabel()
    {
        if (selected is null || string.IsNullOrWhiteSpace(selected.HitDiceMax)) return string.Empty;
        var first = selected.HitDiceMax.Split('+')[0].Trim();
        var idx = first.IndexOf('d');
        if (idx < 0) return string.Empty;
        var die = first[(idx + 1)..].Trim();
        return die.Length > 0 ? $"d{die}" : string.Empty;
    }

    // ===== Denari =====

    private readonly (string Code, string FullName, Func<Character, int> Get)[] CoinDefs = new (string, string, Func<Character, int>)[]
    {
        ("MR", "Moneta di Rame",   c => c.CopperPieces),
        ("MA", "Moneta di Argento", c => c.SilverPieces),
        ("ME", "Moneta di Elettro", c => c.ElectrumPieces),
        ("MO", "Moneta di Oro",     c => c.GoldPieces),
        ("MP", "Moneta di Platino", c => c.PlatinumPieces)
    };

    private double CurrencyTotalGold()
    {
        if (selected is null) return 0;
        return selected.CopperPieces / 100.0
             + selected.SilverPieces / 10.0
             + selected.ElectrumPieces / 2.0
             + selected.GoldPieces
             + selected.PlatinumPieces * 10.0;
    }

    private string ResourcesSummary
    {
        get
        {
            if (selected is null) return string.Empty;
            var dicePart = string.IsNullOrWhiteSpace(selected.HitDiceMax)
                ? "—"
                : $"{CharacterCalculations.GetHitDiceRemaining(selected)}/{HitDiceTotal()}";
            var gold = CurrencyTotalGold()
                .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
            return $"{dicePart} dadi · {gold} mo";
        }
    }

    private string KnowledgeSummary
    {
        get
        {
            if (selected is null) return string.Empty;
            var parts = new List<string>();
            var langCount = string.IsNullOrWhiteSpace(selected.Languages)
                ? 0
                : selected.Languages.Split(new[] { ',', ';', '\n' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
            parts.Add($"{langCount} lingue");
            if (!string.IsNullOrWhiteSpace(selected.SpeciesTraits)) parts.Add("tratti");
            if (!string.IsNullOrWhiteSpace(selected.ClassFeatures)) parts.Add("privilegi");
            if (!string.IsNullOrWhiteSpace(selected.Feats)) parts.Add("talenti");
            return string.Join(" · ", parts);
        }
    }

    private string? AttunementValue(int slot) => slot switch
    {
        1 => selected?.AttunedItem1,
        2 => selected?.AttunedItem2,
        3 => selected?.AttunedItem3,
        _ => null
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            playerId = await AuthState.GetPlayerIdAsync();
            var role = await AuthState.GetRoleAsync();
            isMaster = string.Equals(role, "Master", StringComparison.OrdinalIgnoreCase);

            if (string.IsNullOrEmpty(playerId))
            {
                // AuthRedirect will navigate away; keep loading state.
                return;
            }

            var charsFetch = isMaster
                ? SupabaseService.GetAllCharactersAsync()
                : SupabaseService.GetCharactersForPlayerAsync(playerId);
            var racesTask = SupabaseService.GetAllRacesAsync();
            var classesTask = SupabaseService.GetAllClassesAsync();

            await Task.WhenAll(charsFetch, racesTask, classesTask);

            characters = charsFetch.Result;
            races = racesTask.Result;
            classes = classesTask.Result;

            await UpdateModeFromCharactersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento: {ex.Message}";
            mode = ViewMode.Empty;
        }
    }

    private async Task UpdateModeFromCharactersAsync()
    {
        if (isMaster)
        {
            mode = ViewMode.List;
        }
        else if (characters.Count == 0)
        {
            mode = ViewMode.Empty;
        }
        else if (characters.Count == 1)
        {
            await OpenDetailAsync(characters[0]);
        }
        else
        {
            mode = ViewMode.List;
        }
    }

    private async Task OpenDetailAsync(Character c)
    {
        selected = c;
        notesDraft = c.Notes ?? string.Empty;
        mode = ViewMode.Detail;
        expandedItemId = null;
        isAddingItem = false;
        await LoadInventoryAsync(c.Id);
    }

    private async Task LoadInventoryAsync(string characterId)
    {
        isLoadingInventory = true;
        try
        {
            inventoryItems = await SupabaseService.GetInventoryForCharacterAsync(characterId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore caricamento inventario: {ex.Message}";
            inventoryItems = new();
        }
        finally
        {
            isLoadingInventory = false;
        }
    }

    private void BackToListOrEmpty()
    {
        if (isMaster || characters.Count > 1)
        {
            mode = ViewMode.List;
        }
        else if (characters.Count == 0)
        {
            mode = ViewMode.Empty;
        }
        else
        {
            Navigation.NavigateTo("");
        }
    }

    private void OpenCreateForm()
    {
        editDraft = new Character
        {
            PlayerId = playerId ?? string.Empty,
            Level = 1,
            ArmorClass = 10,
            HitPoints = 10,
            MaxHitPoints = 10,
            Strength = 10,
            Dexterity = 10,
            Constitution = 10,
            Intelligence = 10,
            Wisdom = 10,
            Charisma = 10
        };
        isRaceCustom = false;
        isClassCustom = false;
        mode = ViewMode.Form;
    }

    private void OpenEditForm()
    {
        if (selected is null) return;
        editDraft = CloneCharacter(selected);
        isRaceCustom = !string.IsNullOrEmpty(editDraft.Race)
            && races.All(r => !string.Equals(r.Name, editDraft.Race, StringComparison.Ordinal));
        isClassCustom = !string.IsNullOrEmpty(editDraft.Class)
            && classes.All(c => !string.Equals(c.Name, editDraft.Class, StringComparison.Ordinal));
        mode = ViewMode.Form;
    }

    private string CurrentRaceSelection =>
        isRaceCustom ? CustomOptionValue : (editDraft.Race ?? string.Empty);

    private string CurrentClassSelection =>
        isClassCustom ? CustomOptionValue : (editDraft.Class ?? string.Empty);

    private void OnRaceSelectionChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        if (val == CustomOptionValue)
        {
            isRaceCustom = true;
            editDraft.Race = string.Empty;
        }
        else
        {
            isRaceCustom = false;
            editDraft.Race = val;
        }
    }

    private void OnClassSelectionChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        if (val == CustomOptionValue)
        {
            isClassCustom = true;
            editDraft.Class = string.Empty;
        }
        else
        {
            isClassCustom = false;
            editDraft.Class = val;
        }
    }

    private static string FormatRaceBonuses(Race race)
    {
        var parts = new List<string>();
        void Add(int val, string label)
        {
            if (val != 0) parts.Add($"{(val > 0 ? "+" : "")}{val} {label}");
        }
        Add(race.StrBonus, "FOR");
        Add(race.DexBonus, "DES");
        Add(race.ConBonus, "COS");
        Add(race.IntBonus, "INT");
        Add(race.WisBonus, "SAG");
        Add(race.ChaBonus, "CAR");
        return parts.Count > 0 ? string.Join(", ", parts) : "nessuno";
    }

    private void CancelForm()
    {
        if (selected is not null)
        {
            mode = ViewMode.Detail;
        }
        else if (isMaster || characters.Count > 0)
        {
            mode = ViewMode.List;
        }
        else
        {
            mode = ViewMode.Empty;
        }
    }

    private async Task SaveFormAsync()
    {
        if (string.IsNullOrWhiteSpace(editDraft.Name))
        {
            errorMessage = "Il nome è obbligatorio";
            return;
        }
        if (editDraft.MaxHitPoints < 1)
        {
            errorMessage = "Gli HP massimi devono essere almeno 1";
            return;
        }
        if (editDraft.HitPoints > editDraft.MaxHitPoints)
        {
            editDraft.HitPoints = editDraft.MaxHitPoints;
        }

        isBusy = true;
        errorMessage = null;
        try
        {
            Character? saved;
            if (string.IsNullOrEmpty(editDraft.Id))
            {
                editDraft.PlayerId = playerId ?? string.Empty;
                saved = await SupabaseService.CreateCharacterAsync(editDraft);
            }
            else
            {
                saved = await SupabaseService.UpdateCharacterAsync(editDraft);
            }

            if (saved is null)
            {
                errorMessage = "Il server non ha restituito il personaggio salvato.";
                return;
            }

            var idx = characters.FindIndex(c => c.Id == saved.Id);
            if (idx >= 0) characters[idx] = saved;
            else characters.Add(saved);

            await OpenDetailAsync(saved);
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task AdjustHpAsync(int delta)
    {
        if (selected is null) return;

        var newHp = Math.Clamp(selected.HitPoints + delta, 0, selected.MaxHitPoints);
        if (newHp == selected.HitPoints) return;

        var previous = selected.HitPoints;
        selected.HitPoints = newHp;
        isSavingHp = true;
        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                selected.HitPoints = saved.HitPoints;
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            selected.HitPoints = previous;
            errorMessage = $"Errore salvataggio HP: {ex.Message}";
        }
        finally
        {
            isSavingHp = false;
        }
    }

    private async Task SaveNotesAsync()
    {
        if (selected is null) return;

        var previous = selected.Notes;
        selected.Notes = notesDraft;
        isSavingNotes = true;
        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                selected.Notes = saved.Notes;
                notesDraft = saved.Notes ?? string.Empty;
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            selected.Notes = previous;
            errorMessage = $"Errore salvataggio note: {ex.Message}";
        }
        finally
        {
            isSavingNotes = false;
        }
    }

    private async Task SaveCharacterAsync()
    {
        if (selected is null) return;

        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateCharacterAsync(selected);
            if (saved is not null)
            {
                SyncListFromSelected();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore salvataggio caratteristiche: {ex.Message}";
        }
    }

    // ===== Azioni vital signs / risorse =====

    private async Task CycleDeathSuccessAsync()
    {
        if (selected is null || !CanEdit) return;
        selected.DeathSaveSuccesses = selected.DeathSaveSuccesses >= 3 ? 0 : selected.DeathSaveSuccesses + 1;
        await SaveCharacterAsync();
    }

    private async Task CycleDeathFailureAsync()
    {
        if (selected is null || !CanEdit) return;
        selected.DeathSaveFailures = selected.DeathSaveFailures >= 3 ? 0 : selected.DeathSaveFailures + 1;
        await SaveCharacterAsync();
    }

    private async Task ToggleHeroicInspirationAsync()
    {
        if (selected is null || !CanEdit) return;
        selected.HeroicInspiration = !selected.HeroicInspiration;
        await SaveCharacterAsync();
    }

    private async Task AdjustHitDiceSpentAsync(int delta)
    {
        if (selected is null || !CanEdit) return;
        var total = HitDiceTotal();
        var v = Math.Clamp(selected.HitDiceSpent + delta, 0, total);
        if (v == selected.HitDiceSpent) return;
        selected.HitDiceSpent = v;
        await SaveCharacterAsync();
    }

    private async Task AdjustCoinAsync(string code, int delta)
    {
        if (selected is null || !CanEdit) return;
        switch (code)
        {
            case "MR": selected.CopperPieces = Math.Max(0, selected.CopperPieces + delta); break;
            case "MA": selected.SilverPieces = Math.Max(0, selected.SilverPieces + delta); break;
            case "ME": selected.ElectrumPieces = Math.Max(0, selected.ElectrumPieces + delta); break;
            case "MO": selected.GoldPieces = Math.Max(0, selected.GoldPieces + delta); break;
            case "MP": selected.PlatinumPieces = Math.Max(0, selected.PlatinumPieces + delta); break;
            default: return;
        }
        await SaveCharacterAsync();
    }

    private async Task SetAttunementAsync(int slot, string? raw)
    {
        if (selected is null || !CanEdit) return;
        var val = string.IsNullOrWhiteSpace(raw) ? null : raw.Trim();
        switch (slot)
        {
            case 1: selected.AttunedItem1 = val; break;
            case 2: selected.AttunedItem2 = val; break;
            case 3: selected.AttunedItem3 = val; break;
            default: return;
        }
        await SaveCharacterAsync();
    }

    private void SyncListFromSelected()
    {
        if (selected is null) return;
        var idx = characters.FindIndex(c => c.Id == selected.Id);
        if (idx >= 0) characters[idx] = selected;
    }

    private static Character CloneCharacter(Character c) => new()
    {
        Id = c.Id,
        PlayerId = c.PlayerId,
        Name = c.Name,
        Class = c.Class,
        Race = c.Race,
        Level = c.Level,
        HitPoints = c.HitPoints,
        MaxHitPoints = c.MaxHitPoints,
        ArmorClass = c.ArmorClass,
        Strength = c.Strength,
        Dexterity = c.Dexterity,
        Constitution = c.Constitution,
        Intelligence = c.Intelligence,
        Wisdom = c.Wisdom,
        Charisma = c.Charisma,
        Notes = c.Notes,
        CreatedAt = c.CreatedAt
    };

    // ====================== Inventory ======================

    private void ToggleItemExpand(string id)
    {
        expandedItemId = expandedItemId == id ? null : id;
    }

    private void OpenAddItemForm()
    {
        if (!CanEditInventory || selected is null) return;
        newItemDraft = new InventoryItem
        {
            CharacterId = selected.Id,
            Quantity = 1,
            ItemType = ItemTypeOptions[0].Value
        };
        isAddingItem = true;
        errorMessage = null;
    }

    private void CancelAddItem()
    {
        isAddingItem = false;
        newItemDraft = new InventoryItem();
    }

    private async Task SaveNewItemAsync()
    {
        if (!CanEditInventory || selected is null) return;

        if (string.IsNullOrWhiteSpace(newItemDraft.Name))
        {
            errorMessage = "Il nome dell'oggetto è obbligatorio";
            return;
        }
        if (newItemDraft.Quantity < 1) newItemDraft.Quantity = 1;

        isSavingInventory = true;
        errorMessage = null;
        try
        {
            newItemDraft.CharacterId = selected.Id;
            var saved = await SupabaseService.CreateInventoryItemAsync(newItemDraft);
            if (saved is null)
            {
                errorMessage = "Il server non ha restituito l'oggetto salvato.";
                return;
            }

            inventoryItems.Add(saved);
            inventoryItems = inventoryItems
                .OrderBy(i => i.ItemType ?? string.Empty, StringComparer.OrdinalIgnoreCase)
                .ThenBy(i => i.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();

            isAddingItem = false;
            newItemDraft = new InventoryItem();
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore creazione oggetto: {ex.Message}";
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task AdjustQuantityAsync(InventoryItem item, int delta)
    {
        if (!CanEditInventory) return;

        var newQty = item.Quantity + delta;

        if (newQty <= 0)
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm",
                $"Eliminare \"{item.Name}\" dall'inventario?");
            if (!confirmed) return;
            await DeleteItemInternalAsync(item);
            return;
        }

        var previous = item.Quantity;
        item.Quantity = newQty;
        isSavingInventory = true;
        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateInventoryItemAsync(item);
            if (saved is not null)
            {
                item.Quantity = saved.Quantity;
            }
        }
        catch (Exception ex)
        {
            item.Quantity = previous;
            errorMessage = $"Errore salvataggio quantità: {ex.Message}";
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task ToggleEquippedAsync(InventoryItem item, bool newValue)
    {
        if (!CanEditInventory) return;
        if (item.IsEquipped == newValue) return;

        var previous = item.IsEquipped;
        item.IsEquipped = newValue;
        isSavingInventory = true;
        errorMessage = null;
        try
        {
            var saved = await SupabaseService.UpdateInventoryItemAsync(item);
            if (saved is not null)
            {
                item.IsEquipped = saved.IsEquipped;
            }
        }
        catch (Exception ex)
        {
            item.IsEquipped = previous;
            errorMessage = $"Errore salvataggio equipaggiamento: {ex.Message}";
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private async Task DeleteItemAsync(InventoryItem item)
    {
        if (!CanEditInventory) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Eliminare \"{item.Name}\" dall'inventario?");
        if (!confirmed) return;

        await DeleteItemInternalAsync(item);
    }

    private async Task DeleteItemInternalAsync(InventoryItem item)
    {
        isSavingInventory = true;
        errorMessage = null;
        try
        {
            await SupabaseService.DeleteInventoryItemAsync(item.Id);
            inventoryItems.RemoveAll(i => i.Id == item.Id);
            if (expandedItemId == item.Id) expandedItemId = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore eliminazione oggetto: {ex.Message}";
        }
        finally
        {
            isSavingInventory = false;
        }
    }

    private static string FormatWeight(double weight)
    {
        if (weight <= 0) return "0";
        return weight.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }
}
