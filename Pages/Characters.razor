@page "/characters"
@using DndCompanion.Models
@inject SupabaseService SupabaseService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Personaggi - D&amp;D Companion</PageTitle>

<div class="characters-container">
    @if (selected == null)
    {
        <header class="page-header">
            <button type="button" class="back-btn" @onclick='() => Navigation.NavigateTo("")'>
                ← Home
            </button>
            <h1 class="page-title">Personaggi</h1>
        </header>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-banner" @onclick="() => errorMessage = null">@errorMessage</div>
    }

    @switch (mode)
    {
        case ViewMode.Loading:
            <div class="state-message">Caricamento...</div>
            break;

        case ViewMode.Empty:
            <div class="empty-state">
                <div class="empty-icon">🗡️</div>
                <p class="empty-text">Non hai ancora un personaggio.</p>
                <button type="button" class="primary-btn" @onclick="OpenCreateForm">
                    Crea Personaggio
                </button>
            </div>
            break;

        case ViewMode.List:
            <div class="list-view">
                @if (characters.Count == 0)
                {
                    <div class="state-message">Nessun personaggio trovato.</div>
                }
                else
                {
                    <div class="char-list">
                        @foreach (var c in characters)
                        {
                            <button type="button" class="list-card" @onclick="() => OpenDetailAsync(c)">
                                <div class="list-name">@c.Name</div>
                                <div class="list-meta">Liv @c.Level · @c.Class · @c.Race</div>
                                <div class="list-hp">PF @c.HitPoints / @c.MaxHitPoints</div>
                            </button>
                        }
                    </div>
                }
            </div>
            break;

        case ViewMode.Detail when selected is not null:
            <div class="char-sheet">
                @* ===== Header unificato ===== *@
                <div class="character-header">
                    <button class="header-btn back-btn" @onclick="GoBack" aria-label="Indietro">←</button>
                    <div class="character-title">
                        <h1 class="character-name">@selected.Name</h1>
                        <p class="character-subtitle">
                            Liv @selected.Level · @selected.Class@(string.IsNullOrWhiteSpace(selected.Subclass) ? "" : $" {selected.Subclass}") · @selected.Race
                        </p>
                    </div>
                    @if (CanEdit)
                    {
                        <button class="header-btn edit-btn" @onclick="StartEdit" aria-label="Modifica">✎</button>
                    }
                </div>

                @* ===== Tab bar ===== *@
                <div class="tab-bar">
                    <button class="tab-item @(activeTab == "combat" ? "active" : "")" @onclick='() => activeTab = "combat"'>
                        <span class="tab-icon">⚔</span>
                        <span class="tab-label">Combat</span>
                    </button>
                    <button class="tab-item @(activeTab == "stats" ? "active" : "")" @onclick='() => activeTab = "stats"'>
                        <span class="tab-icon">📊</span>
                        <span class="tab-label">Stats</span>
                    </button>
                    <button class="tab-item @(activeTab == "bio" ? "active" : "")" @onclick='() => activeTab = "bio"'>
                        <span class="tab-icon">👤</span>
                        <span class="tab-label">Bio</span>
                    </button>
                    <button class="tab-item @(activeTab == "items" ? "active" : "")" @onclick='() => activeTab = "items"'>
                        <span class="tab-icon">🎒</span>
                        <span class="tab-label">Items</span>
                    </button>
                    @if (!string.IsNullOrWhiteSpace(selected.SpellcastingAbility))
                    {
                        <button class="tab-item @(activeTab == "magic" ? "active" : "")" @onclick='() => activeTab = "magic"'>
                            <span class="tab-icon">✨</span>
                            <span class="tab-label">Magic</span>
                        </button>
                    }
                </div>

                <div class="tab-content">

                @* ===================== TAB COMBAT ===================== *@
                @if (activeTab == "combat")
                {
                    var weapons = inventoryItems.Where(i => string.Equals(i.ItemType, "weapon", StringComparison.OrdinalIgnoreCase)).ToList();
                    <div class="combat-vitals">
                        <div class="hp-card">
                            <p class="card-label">PUNTI FERITA</p>
                            <div class="hp-row">
                                <button class="hp-circle hp-minus" @onclick="DecreaseHp"
                                        disabled="@(!CanEdit || isSavingHp || selected.HitPoints <= 0)">−</button>
                                <p class="hp-value">@selected.HitPoints<span class="hp-max">/@selected.MaxHitPoints</span></p>
                                <button class="hp-circle hp-plus" @onclick="IncreaseHp"
                                        disabled="@(!CanEdit || isSavingHp || selected.HitPoints >= selected.MaxHitPoints)">+</button>
                            </div>
                            @if (selected.TempHitPoints > 0)
                            {
                                <p class="temp-hp">+@selected.TempHitPoints temp</p>
                            }
                        </div>
                        <div class="ac-card">
                            <p class="card-label">CA</p>
                            <p class="ac-value">@selected.ArmorClass</p>
                        </div>
                    </div>

                    @if (ShowDeathSaves)
                    {
                        <div class="death-saves-card">
                            <p class="card-label">TIRI SALVEZZA CONTRO MORTE</p>
                            <div class="death-saves-row">
                                <div class="death-saves-group">
                                    <span class="ds-label success">Successi</span>
                                    <div class="ds-dots">
                                        @for (int i = 1; i <= 3; i++)
                                        {
                                            var n = i;
                                            <span class="ds-dot @(selected.DeathSaveSuccesses >= n ? "filled success" : "")"
                                                  @onclick="() => SetDeathSaveSuccesses(n == selected.DeathSaveSuccesses ? n - 1 : n)"></span>
                                        }
                                    </div>
                                </div>
                                <div class="death-saves-group">
                                    <span class="ds-label failure">Fallimenti</span>
                                    <div class="ds-dots">
                                        @for (int i = 1; i <= 3; i++)
                                        {
                                            var n = i;
                                            <span class="ds-dot @(selected.DeathSaveFailures >= n ? "filled failure" : "")"
                                                  @onclick="() => SetDeathSaveFailures(n == selected.DeathSaveFailures ? n - 1 : n)"></span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="secondary-stats">
                        <div class="mini-stat">
                            <p class="mini-label">INI</p>
                            <p class="mini-value mini-value-large">@FormatBonus(CharacterCalculations.GetInitiative(selected))</p>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-label">VEL</p>
                            <p class="mini-value">@selected.Speed<span class="mini-unit">m</span></p>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-label">PERC</p>
                            <p class="mini-value">@CharacterCalculations.GetPassivePerception(selected)</p>
                        </div>
                        <div class="mini-stat">
                            <p class="mini-label">ISPIRAZIONE</p>
                            <span class="inspiration-toggle @(selected.HeroicInspiration ? "active" : "")"
                                  @onclick="ToggleHeroicInspiration"></span>
                        </div>
                    </div>

                    <p class="section-header">ARMI</p>
                    @if (weapons.Any())
                    {
                        @foreach (var w in weapons)
                        {
                            <div class="weapon-card">
                                <div class="weapon-header">
                                    <p class="weapon-name">@w.Name</p>
                                    <p class="weapon-stats">
                                        @if (!string.IsNullOrWhiteSpace(w.AttackBonus)) { <span>@w.AttackBonus</span> }
                                        @if (!string.IsNullOrWhiteSpace(w.Damage)) { <span>· @w.Damage @w.DamageType?.ToLower()</span> }
                                    </p>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(w.AttackNotes))
                                {
                                    <p class="weapon-notes">@w.AttackNotes</p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="empty-note">Nessuna arma equipaggiata</p>
                    }

                    @if (HasDefenses)
                    {
                        <p class="section-header">DIFESE</p>
                        <div class="defenses-badges">
                            @if (!string.IsNullOrWhiteSpace(selected.DamageResistances))
                            {
                                @foreach (var item in SplitDefenses(selected.DamageResistances))
                                {
                                    <span class="defense-badge resistance">RES @item</span>
                                }
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.DamageImmunities))
                            {
                                @foreach (var item in SplitDefenses(selected.DamageImmunities))
                                {
                                    <span class="defense-badge immunity">IMM @item</span>
                                }
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.DamageVulnerabilities))
                            {
                                @foreach (var item in SplitDefenses(selected.DamageVulnerabilities))
                                {
                                    <span class="defense-badge vulnerability">VUL @item</span>
                                }
                            }
                            @if (!string.IsNullOrWhiteSpace(selected.ConditionImmunities))
                            {
                                @foreach (var item in SplitDefenses(selected.ConditionImmunities))
                                {
                                    <span class="defense-badge condition-immunity">IMM @item</span>
                                }
                            }
                        </div>
                    }
                }

                @* ===================== TAB STATS ===================== *@
                @if (activeTab == "stats")
                {
                    <div class="stats-header">
                        <p class="bc-display">Bonus di Competenza: <strong>@FormatBonus(CharacterCalculations.GetProficiencyBonus(selected.Level))</strong></p>
                    </div>
                    <div class="stats-grid">
                        <StatCard Ability="AbilityType.Strength"     Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Dexterity"    Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Constitution" Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Intelligence" Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Wisdom"       Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                        <StatCard Ability="AbilityType.Charisma"     Character="@selected" IsEditMode="@CanEdit" OnChanged="@SaveCharacterAsync" />
                    </div>
                }

                @* ===================== TAB BIO ===================== *@
                @if (activeTab == "bio")
                {
                    <div class="bio-blocks">
                        <div class="bio-row">
                            <span class="bio-label">Allineamento</span>
                            <span class="bio-value">@(string.IsNullOrWhiteSpace(selected.Alignment) ? "—" : selected.Alignment)</span>
                        </div>
                        <div class="bio-row">
                            <span class="bio-label">Background</span>
                            <span class="bio-value">@(string.IsNullOrWhiteSpace(selected.Background) ? "—" : selected.Background)</span>
                        </div>
                        <div class="bio-row">
                            <span class="bio-label">Lingue</span>
                            <span class="bio-value">@(string.IsNullOrWhiteSpace(selected.Languages) ? "—" : selected.Languages)</span>
                        </div>
                        <div class="bio-row">
                            <span class="bio-label">Esperienza</span>
                            <span class="bio-value">@selected.ExperiencePoints PE</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(selected.Appearance))
                        {
                            <div class="bio-block">
                                <p class="bio-block-title">ASPETTO</p>
                                <p class="bio-block-text">@selected.Appearance</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(selected.Backstory))
                        {
                            <div class="bio-block">
                                <p class="bio-block-title">STORIA</p>
                                <p class="bio-block-text">@selected.Backstory</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(selected.SpeciesTraits))
                        {
                            <div class="bio-block">
                                <p class="bio-block-title">TRATTI DELLA SPECIE</p>
                                <p class="bio-block-text">@selected.SpeciesTraits</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(selected.ClassFeatures))
                        {
                            <div class="bio-block">
                                <p class="bio-block-title">PRIVILEGI DI CLASSE</p>
                                <p class="bio-block-text">@selected.ClassFeatures</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(selected.Feats))
                        {
                            <div class="bio-block">
                                <p class="bio-block-title">TALENTI</p>
                                <p class="bio-block-text">@selected.Feats</p>
                            </div>
                        }

                        <div class="bio-block">
                            <p class="bio-block-title">NOTE LIBERE</p>
                            <textarea class="notes-textarea" rows="5" @bind="notesDraft"
                                      placeholder="Equipaggiamento, background, obiettivi..."></textarea>
                            <button type="button" class="small-btn"
                                    @onclick="SaveNotesAsync"
                                    disabled="@(isSavingNotes || notesDraft == (selected.Notes ?? string.Empty))">
                                @(isSavingNotes ? "Salvataggio..." : "Salva note")
                            </button>
                        </div>
                    </div>
                }

                @* ===================== TAB ITEMS ===================== *@
                @if (activeTab == "items")
                {
                    <div class="resource-row">
                        <p class="card-label">DADI VITA</p>
                        <div class="hit-dice-controls">
                            <button class="mini-btn" @onclick="DecrementHitDice"
                                    disabled="@(!CanEdit || selected.HitDiceSpent <= 0)">−</button>
                            <span class="hit-dice-value">@selected.HitDiceSpent / @HitDiceTotal() usati</span>
                            <button class="mini-btn" @onclick="IncrementHitDice"
                                    disabled="@(!CanEdit || selected.HitDiceSpent >= HitDiceTotal())">+</button>
                            <span class="hit-dice-type">@(string.IsNullOrWhiteSpace(selected.HitDiceMax) ? "—" : selected.HitDiceMax)</span>
                        </div>
                    </div>

                    <p class="section-header">DENARI</p>
                    <div class="coins-grid">
                        @foreach (var coin in CoinDefs)
                        {
                            <div class="coin" title="@coin.FullName">
                                <span class="coin-label">@coin.Code</span>
                                <span class="coin-value">@coin.Get(selected)</span>
                                @if (CanEdit)
                                {
                                    <div class="coin-ctrl">
                                        <button type="button" class="mini-btn"
                                                @onclick="() => AdjustCoinAsync(coin.Code, -1)"
                                                disabled="@(coin.Get(selected) <= 0)">−</button>
                                        <button type="button" class="mini-btn"
                                                @onclick="() => AdjustCoinAsync(coin.Code, 1)">+</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <p class="section-header">SINTONIE OGGETTI MAGICI</p>
                    <div class="attunements">
                        @for (var slot = 1; slot <= 3; slot++)
                        {
                            var n = slot;
                            var val = AttunementValue(n);
                            <div class="attune-row">
                                @if (CanEdit)
                                {
                                    <input class="attune-input" maxlength="80"
                                           placeholder="(slot libero)"
                                           value="@val"
                                           @onchange="e => SetAttunementAsync(n, e.Value?.ToString())" />
                                }
                                else if (!string.IsNullOrWhiteSpace(val))
                                {
                                    <span class="attune-text">✦ @val</span>
                                }
                                else
                                {
                                    <span class="attune-empty">(slot libero)</span>
                                }
                            </div>
                        }
                    </div>

                    <p class="section-header">INVENTARIO</p>
                    <div class="inventory-section">
                        <div class="inv-summary">
                            <span class="inv-summary-item">
                                <strong>@inventoryItems.Sum(i => i.Quantity)</strong> oggetti
                            </span>
                            <span class="inv-summary-sep">·</span>
                            <span class="inv-summary-item">
                                Peso totale: <strong>@FormatWeight(TotalInventoryWeight)</strong>
                            </span>
                        </div>

                        @if (CanEditInventory)
                        {
                            @if (!isAddingItem)
                            {
                                <button type="button" class="inv-add-btn" @onclick="OpenAddItemForm">
                                    + Aggiungi oggetto
                                </button>
                            }
                            else
                            {
                                <div class="inv-form">
                                    <div class="inv-form-grid">
                                        <div class="field field-full">
                                            <label>Nome</label>
                                            <input type="text" class="input" maxlength="80"
                                                   placeholder="Nome dell'oggetto"
                                                   @bind="newItemDraft.Name" />
                                        </div>

                                        <div class="field">
                                            <label>Quantità</label>
                                            <input type="number" class="input" min="1" @bind="newItemDraft.Quantity" />
                                        </div>

                                        <div class="field">
                                            <label>Peso</label>
                                            <input type="number" class="input" step="0.1" min="0"
                                                   @bind="newItemDraft.Weight" />
                                        </div>

                                        <div class="field field-full">
                                            <label>Tipo</label>
                                            <select class="input" @bind="newItemDraft.ItemType">
                                                @foreach (var o in ItemTypeOptions)
                                                {
                                                    <option value="@o.Value">@o.Label</option>
                                                }
                                            </select>
                                        </div>

                                        <div class="field field-full">
                                            <label>Descrizione (opzionale)</label>
                                            <textarea class="input" rows="3"
                                                      @bind="newItemDraft.Description"></textarea>
                                        </div>
                                    </div>

                                    <div class="inv-form-actions">
                                        <button type="button" class="primary-btn"
                                                @onclick="SaveNewItemAsync"
                                                disabled="@isSavingInventory">
                                            @(isSavingInventory ? "Salvataggio..." : "Salva")
                                        </button>
                                        <button type="button" class="secondary-btn"
                                                @onclick="CancelAddItem"
                                                disabled="@isSavingInventory">
                                            Annulla
                                        </button>
                                    </div>
                                </div>
                            }
                        }

                        @if (isLoadingInventory)
                        {
                            <div class="inv-loading">Caricamento inventario...</div>
                        }
                        else if (inventoryItems.Count == 0)
                        {
                            <div class="inv-empty">Nessun oggetto nell'inventario.</div>
                        }
                        else
                        {
                            <div class="inv-list">
                                @foreach (var item in inventoryItems)
                                {
                                    var isItemExpanded = expandedItemId == item.Id;
                                    <div class="inv-item @(item.IsEquipped ? "equipped" : "")">
                                        <div class="inv-row">
                                            <button type="button" class="inv-name-btn"
                                                    @onclick="() => ToggleItemExpand(item.Id)">
                                                @if (item.IsEquipped)
                                                {
                                                    <span class="eq-icon" title="Equipaggiato">⚔️</span>
                                                }
                                                <span class="inv-name-text">@item.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                                {
                                                    <span class="inv-exp-icon">@(isItemExpanded ? "▾" : "▸")</span>
                                                }
                                            </button>

                                            @if (CanEditInventory)
                                            {
                                                <div class="qty-controls">
                                                    <button type="button" class="qty-btn qty-minus"
                                                            @onclick="() => AdjustQuantityAsync(item, -1)"
                                                            disabled="@isSavingInventory">
                                                        −
                                                    </button>
                                                    <span class="qty-value">@item.Quantity</span>
                                                    <button type="button" class="qty-btn qty-plus"
                                                            @onclick="() => AdjustQuantityAsync(item, 1)"
                                                            disabled="@isSavingInventory">
                                                        +
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="qty-readonly">×@item.Quantity</div>
                                            }
                                        </div>

                                        <div class="inv-meta">
                                            @if (!string.IsNullOrWhiteSpace(item.ItemType))
                                            {
                                                <span class="inv-type-badge">@item.ItemType</span>
                                            }
                                            @if (item.Weight.HasValue)
                                            {
                                                <span class="inv-weight">@FormatWeight(item.Weight.Value * item.Quantity)</span>
                                            }

                                            @if (CanEditInventory)
                                            {
                                                <label class="inv-eq-toggle">
                                                    <input type="checkbox" checked="@item.IsEquipped"
                                                           @onchange="@(e => ToggleEquippedAsync(item, (bool)(e.Value ?? false)))"
                                                           disabled="@isSavingInventory" />
                                                    <span>Equipaggiato</span>
                                                </label>

                                                <button type="button" class="inv-delete-btn"
                                                        title="Elimina oggetto"
                                                        @onclick="() => DeleteItemAsync(item)"
                                                        disabled="@isSavingInventory">
                                                    🗑️
                                                </button>
                                            }
                                        </div>

                                        @if (isItemExpanded && !string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <div class="inv-description">@item.Description</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @* ===================== TAB MAGIC ===================== *@
                @if (activeTab == "magic" && !string.IsNullOrWhiteSpace(selected.SpellcastingAbility))
                {
                    <div class="spell-stats">
                        <div class="spell-stat-block">
                            <p class="card-label">CD INCANTESIMO</p>
                            <p class="spell-stat-value">@CharacterCalculations.GetSpellSaveDc(selected)</p>
                        </div>
                        <div class="spell-stat-block">
                            <p class="card-label">BONUS ATTACCO</p>
                            <p class="spell-stat-value">@FormatBonus(CharacterCalculations.GetSpellAttackBonus(selected) ?? 0)</p>
                        </div>
                        <div class="spell-stat-block">
                            <p class="card-label">CARATT.</p>
                            <p class="spell-stat-value">@SpellAbilityShort(selected.SpellcastingAbility)</p>
                        </div>
                    </div>

                    <p class="section-header">SLOT INCANTESIMO</p>
                    @for (int level = 1; level <= 9; level++)
                    {
                        var lvl = level;
                        var max = GetSpellSlotMax(selected, lvl);
                        var used = GetSpellSlotUsed(selected, lvl);
                        if (max > 0)
                        {
                            <div class="spell-slot-row">
                                <span class="spell-slot-level">Liv @lvl</span>
                                <div class="spell-slot-dots">
                                    @for (int i = 1; i <= max; i++)
                                    {
                                        var idx = i;
                                        <span class="spell-slot-dot @(idx > (max - used) ? "spent" : "")"
                                              @onclick="@(() => ToggleSpellSlot(lvl, idx))"></span>
                                    }
                                </div>
                                <span class="spell-slot-count">@(max - used) / @max</span>
                            </div>
                        }
                    }

                    <p class="section-header">INCANTESIMI PREPARATI</p>
                    <p class="empty-note">Lista incantesimi in arrivo nella prossima fase.</p>
                }

                </div>
            </div>
            break;

        case ViewMode.Form:
            <div class="form-view">
                <div class="sheet-top">
                    <button type="button" class="back-link" @onclick="CancelForm">← Annulla</button>
                </div>

                <h2 class="form-title">
                    @(string.IsNullOrEmpty(editDraft.Id) ? "Nuovo Personaggio" : "Modifica Personaggio")
                </h2>

                <div class="form-accordion">

                    @* ===================== 1. IDENTITÀ ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("identity")'>
                            <span class="form-section-chevron">@(formSections["identity"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Identità</span>
                        </button>
                        @if (formSections["identity"])
                        {
                            <div class="form-section-body">
                                <div class="field">
                                    <label>Nome</label>
                                    <input type="text" class="input" maxlength="64" @bind="editDraft.Name" />
                                </div>

                                <div class="field">
                                    <label>Classe</label>
                                    <select class="input" value="@CurrentClassSelection" @onchange="OnClassSelectionChanged">
                                        <option value="">-- Seleziona --</option>
                                        @foreach (var c in classes.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <option value="@c.Name">@c.Name</option>
                                        }
                                        <option value="@CustomOptionValue">Altro (testo libero)</option>
                                    </select>
                                    @if (isClassCustom)
                                    {
                                        <input type="text" class="input custom-input" maxlength="40"
                                               placeholder="Scrivi la classe"
                                               @bind="editDraft.Class" @bind:event="oninput" />
                                    }
                                    @if (SelectedClassInfo is not null)
                                    {
                                        <div class="info-summary">
                                            <strong>Dado vita:</strong> @(string.IsNullOrEmpty(SelectedClassInfo.HitDie) ? "—" : SelectedClassInfo.HitDie)
                                            @if (!string.IsNullOrWhiteSpace(SelectedClassInfo.PrimaryAbility))
                                            {
                                                <span> · <strong>Abilità primaria:</strong> @SelectedClassInfo.PrimaryAbility</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="field">
                                    <label>Sottoclasse</label>
                                    <input type="text" class="input" maxlength="60"
                                           placeholder="es. Berserker, Campione, Evocatore..."
                                           @bind="editDraft.Subclass" />
                                </div>

                                <div class="field">
                                    <label>Razza</label>
                                    <select class="input" value="@CurrentRaceSelection" @onchange="OnRaceSelectionChanged">
                                        <option value="">-- Seleziona --</option>
                                        @foreach (var r in races.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <option value="@r.Name">@r.Name</option>
                                        }
                                        <option value="@CustomOptionValue">Altro (testo libero)</option>
                                    </select>
                                    @if (isRaceCustom)
                                    {
                                        <input type="text" class="input custom-input" maxlength="40"
                                               placeholder="Scrivi la razza"
                                               @bind="editDraft.Race" @bind:event="oninput" />
                                    }
                                    @if (SelectedRaceInfo is not null)
                                    {
                                        <div class="info-summary">
                                            <strong>Bonus razziali:</strong> @FormatRaceBonuses(SelectedRaceInfo)
                                            · <strong>Velocità:</strong> @SelectedRaceInfo.Speed
                                        </div>
                                    }
                                </div>

                                <div class="field">
                                    <label>Livello</label>
                                    <input type="number" class="input" min="1" max="20" @bind="editDraft.Level" />
                                </div>

                                <div class="field">
                                    <label>Background</label>
                                    <input type="text" class="input" maxlength="60"
                                           placeholder="es. Soldato, Criminale, Eremita..."
                                           @bind="editDraft.Background" />
                                </div>

                                <div class="field">
                                    <label>Allineamento</label>
                                    <select class="input" @bind="editDraft.Alignment">
                                        <option value="">-- Nessuno --</option>
                                        <option value="Legale Buono">Legale Buono</option>
                                        <option value="Neutrale Buono">Neutrale Buono</option>
                                        <option value="Caotico Buono">Caotico Buono</option>
                                        <option value="Legale Neutrale">Legale Neutrale</option>
                                        <option value="Neutrale Puro">Neutrale Puro</option>
                                        <option value="Caotico Neutrale">Caotico Neutrale</option>
                                        <option value="Legale Malvagio">Legale Malvagio</option>
                                        <option value="Neutrale Malvagio">Neutrale Malvagio</option>
                                        <option value="Caotico Malvagio">Caotico Malvagio</option>
                                    </select>
                                </div>

                                <div class="field">
                                    <label>Punti Esperienza</label>
                                    <input type="number" class="input" min="0" @bind="editDraft.ExperiencePoints" />
                                </div>
                            </div>
                        }
                    </div>

                    @* ===================== 2. COMBATTIMENTO ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("combat")'>
                            <span class="form-section-chevron">@(formSections["combat"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Combattimento</span>
                        </button>
                        @if (formSections["combat"])
                        {
                            <div class="form-section-body">
                                <div class="field">
                                    <label>Classe Armatura</label>
                                    <input type="number" class="input" min="0" max="40" @bind="editDraft.ArmorClass" />
                                </div>

                                <div class="dual-field">
                                    <div class="field">
                                        <label>PF Correnti</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.HitPoints" />
                                    </div>
                                    <div class="field">
                                        <label>PF Massimi</label>
                                        <input type="number" class="input" min="1" @bind="editDraft.MaxHitPoints" />
                                    </div>
                                </div>

                                <div class="field">
                                    <label>PF Temporanei</label>
                                    <input type="number" class="input" min="0" @bind="editDraft.TempHitPoints" />
                                </div>

                                <div class="field">
                                    <label>Velocità (m)</label>
                                    <input type="number" class="input" min="0" @bind="editDraft.Speed" />
                                    <span class="field-hint">9m = 30 piedi (umano standard)</span>
                                </div>

                                <div class="field">
                                    <label>Taglia</label>
                                    <select class="input" @bind="editDraft.Size">
                                        <option value="Minuscola">Minuscola</option>
                                        <option value="Piccola">Piccola</option>
                                        <option value="Media">Media</option>
                                        <option value="Grande">Grande</option>
                                        <option value="Enorme">Enorme</option>
                                        <option value="Mastodontica">Mastodontica</option>
                                    </select>
                                </div>

                                <div class="field">
                                    <label>Dadi Vita</label>
                                    <input type="text" class="input" maxlength="40"
                                           placeholder="es. 3d12 (barbaro) o 3d12+2d8 (multiclasse)"
                                           @bind="editDraft.HitDiceMax" />
                                    <span class="field-hint">Numero e tipo dado per livello</span>
                                </div>

                                <div class="field">
                                    <label>Dadi Vita spesi</label>
                                    <input type="number" class="input" min="0" @bind="editDraft.HitDiceSpent" />
                                </div>

                                <div class="derived-info">
                                    Iniziativa: <strong>@FormatBonus(CharacterCalculations.GetInitiative(editDraft))</strong>
                                    · Bonus competenza: <strong>@FormatBonus(CharacterCalculations.GetProficiencyBonus(editDraft.Level))</strong>
                                    · Percezione passiva: <strong>@CharacterCalculations.GetPassivePerception(editDraft)</strong>
                                </div>
                            </div>
                        }
                    </div>

                    @* ===================== 3. CARATTERISTICHE E COMPETENZE ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("stats")'>
                            <span class="form-section-chevron">@(formSections["stats"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Caratteristiche e competenze</span>
                        </button>
                        @if (formSections["stats"])
                        {
                            <div class="form-section-body">
                                <div class="score-grid">
                                    <div class="field stat-field">
                                        <label title="Forza">FOR</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Strength" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Strength))</span>
                                    </div>
                                    <div class="field stat-field">
                                        <label title="Destrezza">DES</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Dexterity" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Dexterity))</span>
                                    </div>
                                    <div class="field stat-field">
                                        <label title="Costituzione">COS</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Constitution" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Constitution))</span>
                                    </div>
                                    <div class="field stat-field">
                                        <label title="Intelligenza">INT</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Intelligence" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Intelligence))</span>
                                    </div>
                                    <div class="field stat-field">
                                        <label title="Saggezza">SAG</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Wisdom" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Wisdom))</span>
                                    </div>
                                    <div class="field stat-field">
                                        <label title="Carisma">CAR</label>
                                        <input type="number" class="input" min="1" max="30" @bind="editDraft.Charisma" />
                                        <span class="score-mod">Mod @FormatBonus(CharacterCalculations.GetModifier(editDraft.Charisma))</span>
                                    </div>
                                </div>

                                <div class="sub-block">
                                    <p class="sub-block-title">TIRI SALVEZZA COMPETENTI</p>
                                    <div class="checkbox-col">
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveStrength" /> <span>Forza</span></label>
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveDexterity" /> <span>Destrezza</span></label>
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveConstitution" /> <span>Costituzione</span></label>
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveIntelligence" /> <span>Intelligenza</span></label>
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveWisdom" /> <span>Saggezza</span></label>
                                        <label class="checkbox-row"><input type="checkbox" @bind="editDraft.ProfSaveCharisma" /> <span>Carisma</span></label>
                                    </div>
                                </div>

                                <div class="sub-block">
                                    <p class="sub-block-title">ABILITÀ COMPETENTI</p>
                                    <div class="skill-head">
                                        <span>Skill</span><span>Comp</span><span>Exp</span>
                                    </div>

                                    <p class="skill-group">FORZA</p>
                                    <div class="skill-row">
                                        <span class="skill-name">Atletica</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfAthletics" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpAthletics" />
                                    </div>

                                    <p class="skill-group">DESTREZZA</p>
                                    <div class="skill-row">
                                        <span class="skill-name">Acrobazia</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfAcrobatics" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpAcrobatics" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Rapidità di mano</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfSleightOfHand" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpSleightOfHand" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Furtività</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfStealth" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpStealth" />
                                    </div>

                                    <p class="skill-group">INTELLIGENZA</p>
                                    <div class="skill-row">
                                        <span class="skill-name">Arcano</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfArcana" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpArcana" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Storia</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfHistory" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpHistory" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Indagare</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfInvestigation" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpInvestigation" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Natura</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfNature" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpNature" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Religione</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfReligion" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpReligion" />
                                    </div>

                                    <p class="skill-group">SAGGEZZA</p>
                                    <div class="skill-row">
                                        <span class="skill-name">Addestrare animali</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfAnimalHandling" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpAnimalHandling" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Intuizione</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfInsight" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpInsight" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Medicina</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfMedicine" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpMedicine" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Percezione</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfPerception" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpPerception" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Sopravvivenza</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfSurvival" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpSurvival" />
                                    </div>

                                    <p class="skill-group">CARISMA</p>
                                    <div class="skill-row">
                                        <span class="skill-name">Inganno</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfDeception" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpDeception" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Intimidire</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfIntimidation" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpIntimidation" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Intrattenere</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfPerformance" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpPerformance" />
                                    </div>
                                    <div class="skill-row">
                                        <span class="skill-name">Persuasione</span>
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ProfPersuasion" />
                                        <input type="checkbox" class="skill-check" @bind="editDraft.ExpPersuasion" />
                                    </div>
                                    <p class="field-hint">L'Expertise senza Competenza non ha effetto: i calcoli lo ignorano.</p>
                                </div>
                            </div>
                        }
                    </div>

                    @* ===================== 4. DIFESE ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("defenses")'>
                            <span class="form-section-chevron">@(formSections["defenses"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Difese</span>
                        </button>
                        @if (formSections["defenses"])
                        {
                            <div class="form-section-body">
                                <div class="field">
                                    <label>Resistenze ai danni</label>
                                    <textarea class="input" rows="2" placeholder="Contundente, Perforante, Tagliente"
                                              @bind="editDraft.DamageResistances"></textarea>
                                </div>
                                <div class="field">
                                    <label>Immunità ai danni</label>
                                    <textarea class="input" rows="2" placeholder="Veleno, Necrotico"
                                              @bind="editDraft.DamageImmunities"></textarea>
                                </div>
                                <div class="field">
                                    <label>Vulnerabilità ai danni</label>
                                    <textarea class="input" rows="2" placeholder="Fuoco, Radiante"
                                              @bind="editDraft.DamageVulnerabilities"></textarea>
                                </div>
                                <div class="field">
                                    <label>Immunità a condizioni</label>
                                    <textarea class="input" rows="2" placeholder="Avvelenato, Spaventato, Charmato"
                                              @bind="editDraft.ConditionImmunities"></textarea>
                                </div>
                                <p class="field-hint">Separa più voci con virgola.</p>
                            </div>
                        }
                    </div>

                    @* ===================== 5. ASPETTO E STORIA ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("lore")'>
                            <span class="form-section-chevron">@(formSections["lore"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Aspetto e storia</span>
                        </button>
                        @if (formSections["lore"])
                        {
                            <div class="form-section-body">
                                <div class="field">
                                    <label>Aspetto</label>
                                    <textarea class="input" rows="3" placeholder="Altezza, capelli, occhi, segni distintivi..."
                                              @bind="editDraft.Appearance"></textarea>
                                </div>
                                <div class="field">
                                    <label>Storia / Backstory</label>
                                    <textarea class="input" rows="6" placeholder="Origini, famiglia, eventi salienti..."
                                              @bind="editDraft.Backstory"></textarea>
                                </div>
                                <div class="field">
                                    <label>Lingue</label>
                                    <input type="text" class="input" maxlength="200"
                                           placeholder="Comune, Orchesco, Nanico..."
                                           @bind="editDraft.Languages" />
                                </div>
                                <div class="field">
                                    <label>Tratti della specie</label>
                                    <textarea class="input" rows="4" placeholder="Scurovisione, Resistenza Implacabile, Furia primordiale..."
                                              @bind="editDraft.SpeciesTraits"></textarea>
                                </div>
                                <div class="field">
                                    <label>Privilegi di classe</label>
                                    <textarea class="input" rows="6" placeholder="Ira, Difesa senza armatura, Padronanza d'armi..."
                                              @bind="editDraft.ClassFeatures"></textarea>
                                </div>
                                <div class="field">
                                    <label>Talenti</label>
                                    <textarea class="input" rows="4" placeholder="Occhio di Gargauth, Combattente difensivo..."
                                              @bind="editDraft.Feats"></textarea>
                                </div>
                                <div class="field">
                                    <label>Note libere</label>
                                    <textarea class="input" rows="4" @bind="editDraft.Notes"></textarea>
                                </div>
                            </div>
                        }
                    </div>

                    @* ===================== 6. RISORSE ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("resources")'>
                            <span class="form-section-chevron">@(formSections["resources"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Risorse</span>
                        </button>
                        @if (formSections["resources"])
                        {
                            <div class="form-section-body">
                                <p class="sub-block-title">DENARI</p>
                                <div class="coins-input-row">
                                    <div class="field coin-field">
                                        <label title="Monete di Rame">MR</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.CopperPieces" />
                                    </div>
                                    <div class="field coin-field">
                                        <label title="Monete di Argento">MA</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.SilverPieces" />
                                    </div>
                                    <div class="field coin-field">
                                        <label title="Monete di Elettro">ME</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.ElectrumPieces" />
                                    </div>
                                    <div class="field coin-field">
                                        <label title="Monete di Oro">MO</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.GoldPieces" />
                                    </div>
                                    <div class="field coin-field">
                                        <label title="Monete di Platino">MP</label>
                                        <input type="number" class="input" min="0" @bind="editDraft.PlatinumPieces" />
                                    </div>
                                </div>

                                <p class="sub-block-title">SINTONIE OGGETTI MAGICI</p>
                                <div class="field">
                                    <label>Slot 1</label>
                                    <input type="text" class="input" maxlength="80"
                                           placeholder="Es. Spada vorpalina, Anello di protezione..."
                                           @bind="editDraft.AttunedItem1" />
                                </div>
                                <div class="field">
                                    <label>Slot 2</label>
                                    <input type="text" class="input" maxlength="80"
                                           placeholder="Es. Spada vorpalina, Anello di protezione..."
                                           @bind="editDraft.AttunedItem2" />
                                </div>
                                <div class="field">
                                    <label>Slot 3</label>
                                    <input type="text" class="input" maxlength="80"
                                           placeholder="Es. Spada vorpalina, Anello di protezione..."
                                           @bind="editDraft.AttunedItem3" />
                                </div>
                                <p class="field-hint">Massimo 3 oggetti magici sintonizzati attivamente.</p>
                            </div>
                        }
                    </div>

                    @* ===================== 7. INCANTESIMI ===================== *@
                    <div class="form-section">
                        <button type="button" class="form-section-header" @onclick='() => ToggleFormSection("spellcasting")'>
                            <span class="form-section-chevron">@(formSections["spellcasting"] ? "▾" : "▸")</span>
                            <span class="form-section-title">Incantesimi</span>
                        </button>
                        @if (formSections["spellcasting"])
                        {
                            <div class="form-section-body">
                                <div class="field">
                                    <label>Caratteristica da incantatore</label>
                                    <select class="input" @bind="editDraft.SpellcastingAbility">
                                        <option value="">-- Nessuna (non incantatore) --</option>
                                        <option value="intelligence">Intelligenza</option>
                                        <option value="wisdom">Saggezza</option>
                                        <option value="charisma">Carisma</option>
                                    </select>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(editDraft.SpellcastingAbility))
                                {
                                    <div class="derived-info">
                                        CD Incantesimo: <strong>@(CharacterCalculations.GetSpellSaveDc(editDraft) ?? 0)</strong>
                                        · Bonus Attacco: <strong>@FormatBonus(CharacterCalculations.GetSpellAttackBonus(editDraft) ?? 0)</strong>
                                    </div>

                                    <p class="sub-block-title">SLOT INCANTESIMO</p>
                                    <div class="spell-slots-head">
                                        <span>Livello</span><span>Massimi</span><span>Usati</span>
                                    </div>
                                    @for (int level = 1; level <= 9; level++)
                                    {
                                        var lvl = level;
                                        <div class="spell-slot-input-row">
                                            <span class="spell-slot-input-label">Liv @lvl</span>
                                            <input type="number" class="input" min="0" max="9"
                                                   value="@GetSpellSlotMax(editDraft, lvl)"
                                                   @onchange="e => OnSpellSlotMaxChanged(lvl, e)" />
                                            <input type="number" class="input" min="0" max="9"
                                                   value="@GetSpellSlotUsed(editDraft, lvl)"
                                                   @onchange="e => OnSpellSlotUsedChanged(lvl, e)" />
                                        </div>
                                    }
                                    <p class="field-hint">Imposta gli slot massimi secondo la tabella della tua classe. Gli slot usati si gestiscono durante la sessione dal tab Magic della scheda.</p>
                                }
                            </div>
                        }
                    </div>

                </div>

                <div class="form-actions">
                    <button type="button" class="primary-btn" @onclick="SaveFormAsync" disabled="@isBusy">
                        @(isBusy ? "Salvataggio..." : "Salva")
                    </button>
                    <button type="button" class="secondary-btn" @onclick="CancelForm" disabled="@isBusy">
                        Annulla
                    </button>
                </div>
            </div>
            break;
    }
</div>

@code {
